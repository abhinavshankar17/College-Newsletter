<%- include("../partials/header") %>  

<div class="container py-5">
  <h2 class="text-center mb-5 fw-bold section-title"> 🎓 Alumni Corner </h2>

  <% if (alumniArticles.length === 0) { %>
    <p class="text-center text-muted">No alumni articles yet.</p>
  <% } %>

  <% alumniArticles.forEach(article => { %>
    <div class="card article-card shadow-lg border-0 mb-5">
      <div class="row g-0">
        <% if (article.alumniImage && article.alumniImage.length > 0) { %>
          <div class="col-md-4">
            <img src="<%= article.alumniImage[0] %>" class="img-fluid alumni-img" alt="Alumni">
          </div>
        <% } else { %>
          <div class="col-md-4">
            <img src="/images/default-alumni.png" class="img-fluid alumni-img" alt="Default Alumni Image">
          </div>
        <% } %>

        <div class="col-md-8">
          <div class="card-body">
            <h3 class="card-title"><%= article.heading %></h3>

            <p class="text-secondary mb-2">
              <strong><%= article.author.name %></strong><br>
              Batch: <%= article.author.batch %><br>
              Dept: <%= article.author.department %>
            </p>

            <p class="card-text text-dark"><%= article.description %></p>

            <small class="text-muted d-block mt-3">
              Posted on <%= article.createdAt.toDateString() %>
            </small>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<style>
  body {
    background: #f4f7fb;
    font-family: "Segoe UI", sans-serif;
  }

  .section-title {
    font-size: 2.2rem;
    color: #0d1b2a;
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.15);
  }

  .article-card {
    border-radius: 15px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .article-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 30px rgba(13, 27, 42, 0.25);
    border-left: 6px solid #415a77;
  }

  .alumni-img {
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .card-title {
    font-size: 1.6rem;
    color: #0d1b2a;
    font-weight: 700;
  }

  .card-text {
    font-size: 1rem;
    line-height: 1.6;
    text-align: justify;
  }

  .article-card:hover .card-title {
    color: #1b263b;
  }
</style>

<%- include("../partials/footer") %>

<style>
  /* Placement Page Container */
  .placement-container {
    font-family: 'Poppins', sans-serif;
    padding: 20px 40px;
    line-height: 1.7;
    color: #1f2937;
  }

  /* Grid Layout */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  /* Base Card Style */
  .stat-card {
    position: relative;
    z-index: 0;
    background: linear-gradient(145deg, #f9fafb, #eef2f3);
    border-radius: 16px;
    padding: 25px;
    text-align: center;
    overflow: hidden;
    box-shadow: 0 6px 15px rgba(0,0,0,0.1);
    transition: transform 0.4s ease, box-shadow 0.4s ease, background 0.6s ease;
  }

  /* Border Glow Layer */
  .stat-card .border {
    position: absolute;
    inset: 0;
    border: 2px solid transparent;
    border-radius: 16px;
    transition: all 0.5s ease;
    pointer-events: none;
    z-index: 1; /* sits above background */
  }

  /* Ensure text sits above the border layer */
  .stat-card * {
    position: relative;
    z-index: 2;
  }

  /* Hover Interaction */
  .stat-card:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 15px 30px rgba(0,0,0,0.18);
  }

  /* Hover Border Colors */
  .stat-card.orange:hover .border { border: 2px solid #ea580c; box-shadow: 0 0 18px #ea580c; }
  .stat-card.blue:hover   .border { border: 2px solid #2563eb; box-shadow: 0 0 18px #2563eb; }
  .stat-card.green:hover  .border { border: 2px solid #16a34a; box-shadow: 0 0 18px #16a34a; }
  .stat-card.purple:hover .border { border: 2px solid #9333ea; box-shadow: 0 0 18px #9333ea; }
  .stat-card.teal:hover   .border { border: 2px solid #0d9488; box-shadow: 0 0 18px #0d9488; }

  /* Typography inside cards */
  .stat-card h2 {
    font-size: 1.9rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .stat-card h3 {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 6px;
  }

  .stat-card p {
    font-size: 1rem;
    color: #374151;
  }

  /* Color Variants */
  .blue   { color: #2563eb; }
  .green  { color: #16a34a; }
  .purple { color: #9333ea; }
  .teal   { color: #0d9488; }
  .orange { color: #ea580c; }

  /* General Headings */
  h1, h2 { font-weight: 600; }

  h1 {
    font-size: 28px;
    margin-bottom: 20px;
  }

  h2 {
    font-size: 22px;
    margin-bottom: 15px;
  }

  /* Section Divider */
  hr {
    margin: 40px 0;
    border: none;
    border-top: 2px dashed #cbd5e1;
  }

  /* Paragraphs */
  .section-text {
    text-align: justify;
    margin-bottom: 20px;
    font-size: 1rem;
    color: #374151;
  }

  /* Highlighted Activities Block */
  .highlighted-activities {
    background: #f9fafb;
    padding: 15px 20px;
    border-left: 4px solid #2563eb;
    border-radius: 8px;
    margin-top: 20px;
  }

  .highlighted-activities h3 {
    color: #1e40af;
    margin-bottom: 10px;
  }

  .highlighted-activities ul {
    margin: 0;
    padding-left: 20px;
  }

  .highlighted-activities li {
    margin-bottom: 8px;
  }
</style>



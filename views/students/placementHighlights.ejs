<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
body{
  font-family: 'Poppins', sans-serif;
  background: linear-gradient(to bottom, #f1f3f9, #e9edf6);
  color:#222;
}

.placement-container{
  padding:40px 60px;
}

/* ===== Heading ===== */
.top-heading h3{
  color:#2b3c8f;
  font-weight:600;
}
.top-heading h1{
  color:#2b3c8f;
  font-weight:800;
  font-size:40px;
}

/* ===== Stat Cards ===== */
.stats-cards{
  display:flex;
  gap:30px;
  margin:40px 0;
}

.stat-box{
  flex:1;
  padding:30px;
  border-radius:25px;
  text-align:center;
  border:2px dashed rgba(0,0,0,0.2);
}

.stat-box h4{
  font-weight:600;
  margin-bottom:15px;
}

.stat-box h2{
  font-size:40px;
  font-weight:800;
}

.green{ background:#cfe7b7; }
.pink{ background:#e5c1d6; }
.blue{ background:#bfe0e6; }

/* ===== Specialization Table ===== */
.spec-title{
  color:#d62828;
  font-weight:800;
  font-size:24px;
  margin:30px 0 15px;
}

.spec-table{
  width:100%;
  border-collapse:collapse;
  font-size:14px;
}

.spec-table th, .spec-table td{
  padding:10px;
  text-align:center;
}

.spec-table thead{
  background:#f4c6c6;
}

.spec-table tbody tr:nth-child(even){
  background:#f7f7f7;
}

.total-row{
  background:#e6d5d5;
  font-weight:700;
}

/* ===== UG Section ===== */
.section-title{
  font-weight:700;
  color:#5a2c7c;
  margin:50px 0 20px;
  font-size:22px;
}

.two-col{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:40px;
  text-align:justify;
}

/* ===== Internship Section ===== */
.intern-title{
  font-weight:800;
  font-size:32px;
  color:#2b3c8f;
  margin:60px 0 30px;
}

.intern-grid{
  display:flex;
  justify-content:space-between;
  gap:30px;
  margin-bottom:40px;
}

.intern-card{
  text-align:center;
  flex:1;
}

.intern-card img{
  width:150px;
  height:150px;
  border-radius:50%;
  border:4px dashed #2b9ed8;
  object-fit:cover;
  margin-bottom:15px;
}

.intern-card h4{
  color:#d62828;
  font-weight:700;
}

/* ===== Company Wise ===== */
.company-title{
  font-weight:700;
  color:#6a1b9a;
  font-size:22px;
  margin:40px 0 20px;
}

.company-columns{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:40px;
  position:relative;
}

.company-columns:after{
  content:"";
  position:absolute;
  left:50%;
  top:0;
  bottom:0;
  border-left:3px dotted #444;
}

/* ===== Bottom Ribbon ===== */
.ribbon{
  margin-top:50px;
  background:#d9b2c8;
  padding:20px;
  text-align:center;
  font-size:20px;
  font-weight:600;
  border-radius:12px;
}

.ribbon strong{
  font-size:24px;
}

/* ===== Mobile Responsive ===== */
@media(max-width:768px){

  .placement-container{
    padding: 20px 15px;
  }

  .top-heading h1{
    font-size: 26px;
  }

  .top-heading h3{
    font-size: 16px;
  }

  /* Stack stat cards vertically */
  .stats-cards{
    flex-direction: column;
    gap: 15px;
  }

  .stat-box{
    padding: 20px;
  }

  .stat-box h2{
    font-size: 28px;
  }

  .stat-box h4{
    font-size: 14px;
  }

  /* Make the wide table scrollable */
  .spec-title{
    font-size: 18px;
  }

  .spec-table{
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    white-space: nowrap;
    font-size: 12px;
  }

  /* Stack two-col text */
  .two-col{
    grid-template-columns: 1fr;
    gap: 15px;
  }

  /* Stack intern cards vertically */
  .intern-title{
    font-size: 22px;
    margin: 30px 0 15px;
  }

  .intern-grid{
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .intern-card img{
    width: 120px;
    height: 120px;
  }

  /* Stack company columns */
  .company-title{
    font-size: 18px;
  }

  .company-columns{
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .company-columns:after{
    display: none;
  }

  .ribbon{
    font-size: 16px;
    padding: 15px;
    margin-top: 30px;
  }

  .ribbon strong{
    font-size: 18px;
  }
}
</style>


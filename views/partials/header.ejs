 <style>
  /* === Navbar dropdowns === */
.navbar-custom {
  background-color: #0d1b2a;
}

.navbar-custom .nav-link,
.navbar-custom .navbar-brand {
  color: #f0f0f0;
}

.navbar-custom .nav-link:hover,
.navbar-custom .navbar-brand:hover {
  color: #ffcc00;
}

.navbar-custom .dropdown-menu {
  background-color: #0d1b2a;
  border: none;
  border-radius: 6px;
  margin-top: 0.25rem;
  left: 0;          /* align with parent */
  right: auto;      /* prevent floating */
  top: 100%;        /* below parent */
  min-width: 220px; /* consistent width */
}

.navbar-custom .dropdown-item {
  color: #f0f0f0;
  transition: all 0.3s ease;
  border-radius: 4px;
  margin: 2px 4px;
}

.navbar-custom .dropdown-item:hover {
  background-color: rgba(255, 204, 0, 0.2);
  color: #ffcc00;
  transform: scale(1.03);
}

/* Ensure dropdown positions relative to parent */
.navbar-custom .nav-item.dropdown {
  position: relative;
}
/* Shift Students dropdown left on desktop only */
@media (min-width: 992px) {
  #studentsDropdown + .dropdown-menu {
    left: -100px;
    right: auto;
  }

  /* Open dropdown on hover for desktop */
  .navbar .dropdown:hover > .dropdown-menu {
    display: block;
    margin-top: 0;
  }
}

/* Mobile dropdown styling */
@media (max-width: 991px) {
  .navbar-custom .dropdown-menu {
    background-color: #162435;
    border: none;
    border-radius: 0;
    padding: 0;
    margin: 0;
    left: 0 !important;
    right: 0 !important;
    position: static !important;
    width: 100%;
    box-shadow: none;
  }

  .navbar-custom .dropdown-item {
    padding: 10px 25px;
    font-size: 0.95rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .navbar-custom .nav-link {
    padding: 10px 15px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
}


 </style>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

 <style>
  /* === Navbar dropdowns === */
.navbar-custom {
  background-color: #0d1b2a;
}

.navbar-custom .nav-link,
.navbar-custom .navbar-brand {
  color: #f0f0f0;
}

.navbar-custom .nav-link:hover,
.navbar-custom .navbar-brand:hover {
  color: #ffcc00;
}

.navbar-custom .dropdown-menu {
  background-color: #0d1b2a;
  border: none;
  border-radius: 6px;
  margin-top: 0.25rem;
  left: 0;          /* align with parent */
  right: auto;      /* prevent floating */
  top: 100%;        /* below parent */
  min-width: 220px; /* consistent width */
}

.navbar-custom .dropdown-item {
  color: #f0f0f0;
  transition: all 0.3s ease;
  border-radius: 4px;
  margin: 2px 4px;
}

.navbar-custom .dropdown-item:hover {
  background-color: rgba(255, 204, 0, 0.2);
  color: #ffcc00;
  transform: scale(1.03);
}

/* Ensure dropdown positions relative to parent */
.navbar-custom .nav-item.dropdown {
  position: relative;
}
#studentsDropdown + .dropdown-menu {
  left: -100px;   /* move 20px to the left */
  right: auto;
}

/* Open dropdown on hover for desktop */
@media (min-width: 992px) {
  .navbar .dropdown:hover > .dropdown-menu {
    display: block;
    margin-top: 0; /* prevent small gap */
  }
}


 </style>
</head>

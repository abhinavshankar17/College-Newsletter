<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= typeof title !== 'undefined' ? title : "College Newsletter" %></title>

  <link rel="stylesheet" href="/style.css">
    <!-- <script src="https://cdn.tailwindcss.com"></script> -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    /* === Extra rules for dropdowns (matching your navbar theme) === */
    .navbar-custom .dropdown-menu {
      background-color: #0d1b2a; /* same as navbar */
      border: none;
      border-radius: 6px;
      margin-top: 0;
    }

    .navbar-custom .dropdown-item {
      color: #f0f0f0;
      transition: all 0.3s ease;
      border-radius: 4px;
      margin: 2px 4px;
    }

    .navbar-custom .dropdown-item:hover {
      background-color: rgba(255, 204, 0, 0.2); /* soft yellow overlay */
      color: #ffcc00;
      transform: scale(1.03);
    }
    

    /* Open dropdown on hover for desktop */
    @media (min-width: 992px) {
      .navbar .dropdown:hover > .dropdown-menu {
        display: block;
      }
    }
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-custom">
  <div class="container" style="margin-top: -1px;">
    <a class="navbar-brand fw-bold" href="/">NWC Newsletter</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">

        <!-- Research -->
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="researchDropdown" role="button"
             data-bs-toggle="dropdown" aria-expanded="false">
            Research
          </a>
          <ul class="dropdown-menu" aria-labelledby="researchDropdown">
            <li><a class="dropdown-item" href="/research-orations">ResearchOration</a></li>
            <li><a class="dropdown-item" href="/research/research-projects">ResearchProjects</a></li>
          </ul>
        </li>

        <!-- Specialization -->
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="specializationDropdown" role="button"
             data-bs-toggle="dropdown" aria-expanded="false">
            Specialization
          </a>
          <ul class="dropdown-menu" aria-labelledby="specializationDropdown">
            <li><a class="dropdown-item" href="/specialization/cloud-computing">CloudComputing</a></li>
            <li><a class="dropdown-item" href="/specialization/computer-networking">ComputerNetworking</a></li>
            <li><a class="dropdown-item" href="/specialization/cyber-security">CyberSecurity</a></li>
            <li><a class="dropdown-item" href="/specialization/information-technology">InformationTechnology</a></li>
            <li><a class="dropdown-item" href="/specialization/internet-of-things">InternetOfThings</a></li>
          </ul>
        </li>

        <!-- Faculty -->
        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" id="facultyDropdown" role="button"
             data-bs-toggle="dropdown" aria-expanded="false">
            Faculty
          </a>
          <ul class="dropdown-menu" aria-labelledby="facultyDropdown">
            <li><a class="dropdown-item" href="/FacultyArticle">FacultyArticle</a></li>
            <li><a class="dropdown-item" href="/phdscholars">Ph.D. Powerhouse</a></li>
            <li><a class="dropdown-item" href="/facultyOnBoard">New On Board</a></li>
            <li><a class="dropdown-item" href="/facultyUpskilling">Faculty Upskilling</a></li>
            <li><a class="dropdown-item" href="/faculty-achievements">Faculty Achievements</a></li>
            <li><a class="dropdown-item" href="/consultancy">Faculty Consultancy</a></li>
          </ul>
        </li>

      </ul>
    </div>
  </div>
</nav>

<main class="container my-4">
  <!-- page content -->
</main>

<!-- Bootstrap JS (bundle includes Popper) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

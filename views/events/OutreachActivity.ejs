<%- include("../partials/header", { title: "Outreach Activities" }) %>

<div class="container my-5">
  <h1 class="mb-5 text-center fw-bold page-title">Outreach Activities</h1>

  <% if (Object.keys(activities).length === 0) { %>
    <p class="text-center text-muted">No Outreach Activities available.</p>
  <% } else { %>
    <% Object.keys(activities).forEach(date => { %>
      <div class="mb-5">
        <h3 class="text-primary mb-4"><%= date %></h3>

        <% activities[date].forEach((activity, index) => { %>
          <div class="card shadow-sm mb-4 rounded-3">
            <div class="card-body">
              <h5 class="card-title"><%= activity.title %></h5>

              <% if (activity.time) { %>
                <p><i class="bi bi-clock me-2"></i><strong>Time:</strong> <%= activity.time %></p>
              <% } %>

              <% if (activity.venue && activity.venue.length > 0) { %>
                <p><i class="bi bi-geo-alt me-2"></i><strong>Venue:</strong> <%= activity.venue.join(", ") %></p>
              <% } %>

              <% if (activity.participants) { %>
                <p><i class="bi bi-people me-2"></i><strong>Participants:</strong> <%= activity.participants %></p>
              <% } %>

            <% if (activity.CoOrdinators) { %>
  <div>

    
    <% activity.CoOrdinators.split(',').forEach(role => { %>
      <span style="display:block; font-weight:bold; margin-left:10px;"><%= role.trim() %></span>
    <% }) %>
  </div>
<% } %>

              <% if (activity.EventSummary) { %>
                <p><i class="bi bi-card-text me-2"></i><strong>Summary:</strong> <%= activity.EventSummary %></p>
              <% } %>
            </div>

            <!-- Images gallery -->
            <% if (activity.images && activity.images.length > 0) { %>
              <div class="card-footer bg-white d-flex flex-wrap gap-2">
                <% activity.images.forEach(img => { %>
                  <div style="flex: 1 1 30%; max-width: 30%;">
                    <img src="<%= img %>" class="rounded" style="width:100%; height:150px; object-fit:contain; background:#f0f0f0;" alt="Activity Image">
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="card-footer bg-white">
                <img src="/images/placeholder.png" class="rounded" style="width:100%; height:150px; object-fit:contain; background:#f0f0f0;" alt="No Image">
              </div>
            <% } %>

          </div>
        <% }) %>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include("../partials/footer") %>

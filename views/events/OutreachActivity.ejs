<body class="bg-light" style="font-family: 'Poppins', sans-serif;">
  <%- include("../partials/header", { title: "Outreach Activities" }) %>

  <div class="container my-5">
    <h1 class="mb-5 text-center fw-bold page-title">
      Outreach Activities
    </h1>

    <% if (activities && activities.length) { %>
      <% activities.forEach(activity => { %>
        <!-- One full container per activity -->
        <div class="activity-card mb-5 p-4">
          <!-- Title -->
          <h2 class="mb-4 text-center fw-semibold activity-title">
            <%= activity.title || "Untitled Outreach Activity" %>
          </h2>

          <!-- Basic Details -->
          <div class="activity-details mb-4">
            <p><i class="bi bi-calendar-event text-primary me-2"></i><strong>Date:</strong> <%= activity.date ? activity.date.toDateString() : "Not available" %></p>
            <p><i class="bi bi-clock text-success me-2"></i><strong>Time:</strong> <%= activity.time || "Not available" %></p>
            <p><i class="bi bi-geo-alt text-danger me-2"></i><strong>Venue:</strong> <%= activity.venue || "Not available" %></p>
            <p><i class="bi bi-people text-warning me-2"></i><strong>Participants:</strong> <%= activity.participants || "Not specified" %></p>
            <% if (activity.convener) { %>
              <p><i class="bi bi-person-check text-info me-2"></i><strong>Convener:</strong> <%= activity.convener %></p>
            <% } %>
          </div>

          <!-- Coordinators -->
          <% if (activity.coordinators && activity.coordinators.length) { %>
            <div class="mb-4">
              <h5 class="section-header">👨‍🏫 Coordinators</h5>
              <ul class="list-group list-group-flush">
                <% activity.coordinators.forEach(c => { %>
                  <li class="list-group-item"><%= c.name %> (<%= c.designation %>)</li>
                <% }) %>
              </ul>
            </div>
          <% } %>

          <!-- Co-Conveners -->
          <% if (activity.coConveners && activity.coConveners.length) { %>
            <div class="mb-4">
              <h5 class="section-header">🤝 Co-Conveners</h5>
              <ul class="list-group list-group-flush">
                <% activity.coConveners.forEach(c => { %>
                  <li class="list-group-item"><%= c.name %> (<%= c.designation %>)</li>
                <% }) %>
              </ul>
            </div>
          <% } %>

          <!-- Event Summary -->
          <div class="mb-4">
            <h5 class="section-header">📝 Event Summary</h5>
            <p class="event-summary"><%= activity.eventSummary || "No summary available." %></p>
          </div>

          <!-- Images -->
          <% if (activity.imageUrl && activity.imageUrl.length) { %>
            <div>
              <h5 class="section-header">📸 Event Images</h5>
              <div class="row">
                <% activity.imageUrl.forEach(img => { %>
                  <div class="col-md-4 mb-3">
                    <div class="card h-100 image-card">
                      <img src="<%= img %>" class="card-img-top img-fluid rounded-top" alt="Event image">
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-center text-muted">No Outreach Activities available.</p>
    <% } %>
  </div>

  <%- include("../partials/footer") %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

  <!-- Styling -->
  <style>
    body {
      background-color: #f4f6f9;
    }

    .page-title {
      color: #1a2530; 
      border-bottom: 3px solid #cda434;
      display: inline-block;
      padding-bottom: 5px;
    }

    .activity-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
      transition: all 0.3s ease-in-out;
    }

    .activity-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 28px rgba(0,0,0,0.12);
    }

    .activity-title {
      color: #2c3e50;
      font-size: 1.7rem;
      border-bottom: 2px solid #eee;
      padding-bottom: 8px;
    }

    .activity-details p {
      margin: 6px 0;
      font-size: 0.95rem;
    }

    .section-header {
      font-weight: 600;
      font-size: 1.1rem;
      color: #1a2530;
      margin-bottom: 12px;
      border-left: 4px solid #cda434;
      padding-left: 8px;
    }

    .event-summary {
      background: #fafafa;
      padding: 15px;
      border-radius: 8px;
      line-height: 1.6;
      font-size: 0.96rem;
    }

    .list-group-item {
      border: none;
      padding: 10px 15px;
      background: transparent;
    }

    .image-card {
      border: none;
      border-radius: 12px;
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .image-card img {
      transition: transform 0.3s ease;
    }

    .image-card:hover img {
      transform: scale(1.05);
    }

    .image-card:hover {
      box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    }
  </style>
</body>

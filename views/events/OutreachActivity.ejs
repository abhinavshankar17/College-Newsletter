
<body class="bg-light">
  <%- include("../partials/header", { title: activity?.title || "Outreach Activity" }) %>
  <div class="container my-5">
    <!-- Title -->
    <h1 class="mb-4 text-primary"><%= activity?.title || "Untitled Outreach Activity" %></h1>

    <!-- Basic Details -->
    <div class="card mb-4 shadow-sm">
      <div class="card-body">
        <p><strong>Date:</strong> <%= activity?.date ? activity.date.toDateString() : "Not available" %></p>
        <p><strong>Time:</strong> <%= activity?.time || "Not available" %></p>
        <p><strong>Venue:</strong> <%= activity?.venue || "Not available" %></p>
        <p><strong>Participants:</strong> <%= activity?.participants || "Not specified" %></p>
        <% if (activity?.convener) { %>
          <p><strong>Convener:</strong> <%= activity.convener %></p>
        <% } %>
      </div>
    </div>

    <!-- Coordinators -->
    <% if (activity?.coordinators?.length) { %>
      <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">Coordinators</div>
        <div class="card-body">
          <ul class="list-group">
            <% activity.coordinators.forEach(c => { %>
              <li class="list-group-item"><%= c.name %> (<%= c.designation %>)</li>
            <% }) %>
          </ul>
        </div>
      </div>
    <% } %>

    <!-- Co-Conveners -->
    <% if (activity?.coConveners?.length) { %>
      <div class="card mb-4 shadow-sm">
        <div class="card-header bg-secondary text-white">Co-Conveners</div>
        <div class="card-body">
          <ul class="list-group">
            <% activity.coConveners.forEach(c => { %>
              <li class="list-group-item"><%= c.name %> (<%= c.designation %>)</li>
            <% }) %>
          </ul>
        </div>
      </div>
    <% } %>

    <!-- Event Summary -->
    <div class="card mb-4 shadow-sm">
      <div class="card-header bg-success text-white">Event Summary</div>
      <div class="card-body">
        <p><%= activity?.eventSummary || "No summary available." %></p>
      </div>
    </div>

    <!-- Images -->
    <% if (activity?.images?.length) { %>
      <div class="card shadow-sm">
        <div class="card-header bg-info text-white">Event Images</div>
        <div class="card-body">
          <div class="row">
            <% activity.images.forEach(img => { %>
              <div class="col-md-4 mb-3">
                <div class="card h-100">
                  <img src="<%= img.url %>" class="card-img-top img-fluid" alt="Event image">
                  <div class="card-body">
                    <p class="card-text"><%= img.description || "" %></p>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    <% } %>
  </div>
<%- include("../partials/footer") %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>


<body class="bg-light">
  <!-- Header -->
<%- include("../partials/header", { title: "Guest Lectures" }) %>

<div class="container py-5">
  <h1 class="text-center mb-5 fw-bold text-gradient">🎓 Guest Lectures 🎓</h1>

  <% if (guestLectures && guestLectures.length > 0) { %>
    <div class="row g-4">
      <% guestLectures.forEach(lecture => { %>
        <div class="col-12">
          <div class="card shadow-lg border-0 rounded-4 guest-lecture-card">

            <!-- Card Header -->
            <div class="card-header text-white text-center py-4 rounded-top fw-bold"
                 style="background: linear-gradient(135deg, #1f3a57, #3498db, #1abc9c);">
              <h3 class="mb-0"><%= lecture.title || "Untitled Lecture" %></h3>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4">

              <!-- Conveners -->
              <% if (lecture.conveners && lecture.conveners.name) { %>
                <h6 class="section-title">Convener:</h6>
                <p><i class="bi bi-person-badge"></i> <%= lecture.conveners.name %></p>
              <% } %>

              <!-- Resource Person -->
              <% if (lecture.resourcePerson && lecture.resourcePerson.name) { %>
                <h6 class="section-title">Resource Person:</h6>
                <p><i class="bi bi-person-circle"></i> <%= lecture.resourcePerson.name %></p>
              <% } %>

              <!-- Number of Participants -->
              <p class="mb-3">
                <span class="badge bg-gradient fs-6">
                  👥 <%= lecture.numberOfRegisteredParticipants || 0 %> Registered
                </span>
              </p>

              <!-- Tracks -->
              <% if (lecture.tracks) { %>
                <h6 class="section-title">Tracks:</h6>
                <p><%= lecture.tracks %></p>
              <% } %>

              <!-- Prizes -->
              <% if (lecture.prizes) { %>
                <h6 class="section-title">Prizes:</h6>
                <ul>
                  <% if (lecture.prizes.firstPrize) { %><li>🏆 First Prize: <%= lecture.prizes.firstPrize %></li><% } %>
                  <% if (lecture.prizes.secondPrize) { %><li>🥈 Second Prize: <%= lecture.prizes.secondPrize %></li><% } %>
                  <% if (lecture.prizes.participation) { %><li>🎖 Participation: <%= lecture.prizes.participation %></li><% } %>
                </ul>
              <% } %>

              <!-- Venue -->
              <% if (lecture.venue) { %>
                <h6 class="section-title">Venue:</h6>
                <p><i class="bi bi-geo-alt"></i> <%= lecture.venue %></p>
              <% } %>

              <!-- Registration -->
              <% if (lecture.registration) { %>
                <h6 class="section-title">Registration:</h6>
                <p>Fee: ₹<%= lecture.registration.fee || 0 %> | Team Size: <%= lecture.registration.teamSize || 1 %></p>
              <% } %>

              <!-- Event Summary -->
              <% if (lecture.eventSummary) { %>
                <h6 class="section-title">Summary:</h6>
                <p><%= lecture.eventSummary.replace(/\n/g, "<br>") %></p>
              <% } %>

              <!-- Images -->
              <% if (lecture.images && lecture.images.length > 0) { %>
                <div class="mt-3">
                  <h6 class="fw-bold text-primary">Event Gallery:</h6>
                  <div class="d-flex flex-wrap gap-3">
                    <% lecture.images.forEach(image => { %>
                      <img src="<%= image || '/default.jpg' %>" 
                           alt="Lecture Image" 
                           class="img-thumbnail guest-lecture-image" 
                           style="max-width: 180px; border-radius: 12px;">
                    <% }) %>
                  </div>
                </div>
              <% } %>

            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="alert alert-info text-center shadow-sm p-4 rounded-3">
      🎓 No guest lectures found. Be the first to add one!
    </div>
  <% } %>
</div>

<%- include("../partials/footer") %>

<style>
  .section-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #0a1f44;
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    border-left: 4px solid #f1c40f;
    padding-left: 8px;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

</body>

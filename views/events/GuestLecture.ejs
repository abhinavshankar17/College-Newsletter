<body class="bg-light">
  <!-- Header -->
  <%- include("../partials/header", { title: "Guest Lectures" }) %>

  <style>
    body {
      background: #f8f9fa;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: #333;
    }

    .card {
      border: none;
      border-radius: 15px;
      overflow: hidden;
      margin-bottom: 2rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    }

    .card-body {
      padding: 2rem;
    }

    .card-title {
      font-size: 2rem;
      font-weight: 600;
      color: #0d47a1;
      border-bottom: 2px solid #e3e6ea;
      padding-bottom: 0.5rem;
      margin-bottom: 1.5rem;
    }

    h5 {
      margin-top: 1.5rem;
      font-weight: 600;
      color: #1a237e;
      border-left: 4px solid #0d47a1;
      padding-left: 8px;
    }

    ul {
      padding-left: 1.2rem;
    }

    ul li {
      margin-bottom: 0.4rem;
    }

    .text-muted strong {
      color: #444;
    }

    .img-fluid {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      cursor: pointer;
    }

    .img-fluid:hover {
      transform: scale(1.05);
      box-shadow: 0 6px 16px rgba(0,0,0,0.25);
    }

    .info-box {
      background: #f1f5fb;
      border-left: 4px solid #0d47a1;
      padding: 0.8rem 1rem;
      margin-bottom: 1rem;
      border-radius: 8px;
    }

    .info-box strong {
      color: #0d47a1;
    }
  </style>

  <div class="container my-5">
    <% if (guestLectures && guestLectures.length > 0) { %>
      <% guestLectures.forEach(lecture => { %>
        <div class="card shadow-lg">
          <div class="card-body">
            <!-- Title -->
            <h2 class="card-title"><%= lecture.title %></h2>

            <!-- Date -->
            <p class="text-muted">
              <strong>Date:</strong>
              <%= lecture.date ? new Date(lecture.date).toDateString() : "Not Available" %>
            </p>

            <!-- Conveners -->
            <h5>Conveners:</h5>
            <ul>
              <% if (lecture.conveners?.length > 0) { %>
                <% lecture.conveners.forEach(c => { %>
                  <li><%= c.name %> (<%= c.designation || "No designation" %>)</li>
                <% }) %>
              <% } else { %>
                <li>No conveners listed</li>
              <% } %>
            </ul>

            <!-- Resource Person -->
            <h5>Resource Person:</h5>
            <% if (lecture.resourcePerson) { %>
              <p><%= lecture.resourcePerson.name %> - <%= lecture.resourcePerson.role || "Role not available" %></p>
            <% } else { %>
              <p>No resource person info</p>
            <% } %>

            <!-- Registered Participants -->
            <div class="info-box">
              <strong>Registered Participants:</strong>
              <%= lecture.numberOfRegisteredParticipants || 0 %>
            </div>

            <!-- Tracks -->
            <h5>Tracks:</h5>
            <ul>
              <% if (lecture.tracks?.length > 0) { %>
                <% lecture.tracks.forEach(track => { %>
                  <li><%= track %></li>
                <% }) %>
              <% } else { %>
                <li>No tracks available</li>
              <% } %>
            </ul>

            <!-- Prizes -->
            <h5>Prizes:</h5>
            <ul>
              <li>First Prize: <%= lecture.prizes?.firstPrize || "Not specified" %></li>
              <li>Second Prize: <%= lecture.prizes?.secondPrize || "Not specified" %></li>
              <li>Participation: <%= lecture.prizes?.participation || "Not specified" %></li>
            </ul>

            <!-- Venue -->
            <p class="mt-3"><strong>Venue:</strong> <%= lecture.venue || "Not specified" %></p>

            <!-- Registration -->
            <div class="info-box">
              <strong>Registration:</strong>
              Fee: ₹<%= lecture.registration?.fee ?? "N/A" %> |
              Team Size: <%= lecture.registration?.teamSize ?? "N/A" %>
            </div>

            <!-- Event Summary -->
            <h5>Event Summary:</h5>
            <p><%= lecture.eventSummary || "No summary provided" %></p>

            <!-- Images -->
            <h5>Images:</h5>
            <div class="row">
              <% if (lecture.imageUrl?.length > 0) { %>
                <% lecture.imageUrl.forEach(url => { %>
                  <div class="col-md-4 mb-3">
                    <img src="<%= url %>" class="img-fluid rounded shadow-sm" alt="Event Image">
                  </div>
                <% }) %>
              <% } else { %>
                <p>No images available</p>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p>No guest lectures found.</p>
    <% } %>
  </div>

  <!-- Footer -->
  <%- include("../partials/footer") %>
</body>

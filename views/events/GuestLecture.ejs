<body class="bg-light">
  <!-- Header -->
  <%- include("../partials/header", { title: "Guest Lectures" }) %>

  <div class="container py-5">
    <h1 class="text-center mb-5 fw-bold display-5" style="color: #0a1f44;">🎓 Guest Lectures 🎓</h1>

    <% if (guestLectures && guestLectures.length > 0) { %>
      <div class="row g-4">
        <% guestLectures.forEach(lecture => { %>
          <div class="col-12">
            <div class="card shadow-lg border-0 rounded-4 guest-lecture-card overflow-hidden">

              <!-- Card Header -->
              <div class="card-header text-white text-center py-4 fw-bold guest-lecture-header">
                <h3 class="mb-0"><%= lecture.title || "Untitled Lecture" %></h3>
              </div>

              <!-- Card Body -->
              <div class="card-body p-4">

                <!-- Date -->
                <% if (lecture.date) { %>
                  <h6 class="section-title">Date:</h6>
                  <span><i class="bi bi-calendar-event"></i> <%= lecture.date %></span>
                <% } %>

                <!-- Conveners -->
                <% if (lecture.conveners && lecture.conveners.name) { %>
                  <h6 class="section-title">Convener(s):</h6>
                  <div class="conveners-list">
                    <% lecture.conveners.name.split(',').forEach(convener => { %>
                      <span><%= convener.trim() %></span>
                    <% }) %>
                  </div>
                <% } %>

                <!-- Resource Person -->
                <% if (lecture.resourcePerson && lecture.resourcePerson.name) { %>
                  <h6 class="section-title">Resource Person:</h6>
                  <span><i class="bi bi-person-circle"></i> <%= lecture.resourcePerson.name %></span>
                <% } %>

                <!-- Number of Participants -->
                <p class="mb-3">
                  <span class="badge participants-badge fs-6">
                     <%= lecture.numberOfRegisteredParticipants || 0 %> Registered
                  </span>
                </p>

                <!-- Tracks -->
                <% if (lecture.tracks) { %>
                  <h6 class="section-title">Tracks:</h6>
                  <span><%= lecture.tracks %></span>
                <% } %>

                <!-- Prizes -->
                <% if (lecture.prizes) { %>
                  <h6 class="section-title">Prizes:</h6>
                  <ul>
                    <% if (lecture.prizes.firstPrize) { %><li>First Prize: <%= lecture.prizes.firstPrize %></li><% } %>
                    <% if (lecture.prizes.secondPrize) { %><li>Second Prize: <%= lecture.prizes.secondPrize %></li><% } %>
                    <% if (lecture.prizes.participation) { %><li> Participation: <%= lecture.prizes.participation %></li><% } %>
                  </ul>
                <% } %>

                <!-- Venue -->
                <% if (lecture.venue) { %>
                  <h6 class="section-title">Venue:</h6>
                  <span><i class="bi bi-geo-alt"></i> <%= lecture.venue %></span>
                <% } %>

                <!-- Registration -->
                <% if (lecture.registration) { %>
                  <h6 class="section-title">Registration:</h6>
                  <span>Fee: ₹<%= lecture.registration.fee || 0 %> | Team Size: <%= lecture.registration.teamSize || 1 %></span>
                <% } %>

                <!-- Event Summary -->
                <% if (lecture.eventSummary) { %>
                  <h6 class="section-title">Summary:</h6>
                  <span><%= lecture.eventSummary.replace(/\\n/g, "<br>") %></span>
                <% } %>

                <!-- Images -->
                <% if (lecture.images && lecture.images.length > 0) { %>
                  <div class="mt-4">
                    <h6 class="section-title">Event Gallery:</h6>
                    <div class="image-grid-container">
                      <div class="image-grid">
                        <% lecture.images.forEach(image => { %>
                          <img src="<%= image || '/default.jpg' %>" 
                               alt="Lecture Image" 
                               class="img-thumbnail guest-lecture-image">
                        <% }) %>
                      </div>
                    </div>
                  </div>
                <% } %>

              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info text-center shadow-sm p-4 rounded-3">
        🎓 No guest lectures found. Be the first to add one!
      </div>
    <% } %>
  </div>

  <%- include("../partials/footer") %>

  <!-- Custom Styles -->
  <style>
    :root {
      --guest-gradient: linear-gradient(135deg, #1f3a57, #3498db, #1abc9c);
      --accent-color: #f1c40f;
      --title-color: #0a1f44;
      --badge-bg: linear-gradient(45deg, #6a11cb, #2575fc);
    }

    .guest-lecture-header {
      background: var(--guest-gradient);
      border-top-left-radius: 1rem;
      border-top-right-radius: 1rem;
    }

    .guest-lecture-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .guest-lecture-card:hover {
      transform: scale(1.01);
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
    }

    .section-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--title-color);
      margin-top: 1rem;
      margin-bottom: 0.3rem;
      border-left: 5px solid var(--accent-color);
      padding-left: 10px;
    }

    .participants-badge {
      background: var(--badge-bg);
      color: #fff;
      padding: 0.6rem 1rem;
      border-radius: 20px;
    }

    .image-grid-container {
      display: flex;
      justify-content: center;
      margin-top: 1rem;
    }

    .image-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
      max-width: 1000px;
      width: 100%;
      justify-items: center;
    }

    .guest-lecture-image {
      width: 100%;
      max-width: 180px;
      height: 160px;
      object-fit: cover;
      border-radius: 12px;
      transition: transform 0.3s ease;
    }

    .guest-lecture-image:hover {
      transform: scale(1.05);
    }

    /* Make all p and span lines block */
    .guest-lecture-card p, 
    .guest-lecture-card span {
      display: block;
      margin: 4px 0;
      line-height: 1.5;
      font-size: 0.95rem;
    }

    /* Multiple conveners in separate lines */
    .guest-lecture-card .conveners-list span {
      display: block;
    }

    /* Icons spacing */
    .guest-lecture-card p i, 
    .guest-lecture-card span i {
      margin-right: 6px;
      color: #3498db;
    }
  </style>

  <!-- Bootstrap JS and Icons -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</body>


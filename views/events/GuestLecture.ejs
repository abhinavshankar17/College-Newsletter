<body class="bg-light">
  <!-- Header -->
  <%- include("../partials/header", { title: guestLecture?.title || "Guest Lecture" }) %>

  <style>
    body {
      background: #f8f9fa; /* light gray */
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: #333;
    }

    .card {
      border: none;
      border-radius: 15px;
      overflow: hidden;
    }

    .card-body {
      padding: 2rem;
    }

    .card-title {
      font-size: 2rem;
      font-weight: 600;
      color: #0d47a1; /* darker blue */
      border-bottom: 2px solid #e3e6ea;
      padding-bottom: 0.5rem;
      margin-bottom: 1.5rem;
    }

    h5 {
      margin-top: 1.5rem;
      font-weight: 600;
      color: #1a237e;
      border-left: 4px solid #0d47a1;
      padding-left: 8px;
    }

    ul {
      padding-left: 1.2rem;
    }

    ul li {
      margin-bottom: 0.4rem;
    }

    .text-muted strong {
      color: #444;
    }

    .img-fluid {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      cursor: pointer;
    }

    .img-fluid:hover {
      transform: scale(1.05);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
    }

    /* Section spacing */
    p, ul {
      margin-bottom: 1rem;
    }

    /* Highlighted info sections */
    .info-box {
      background: #f1f5fb;
      border-left: 4px solid #0d47a1;
      padding: 0.8rem 1rem;
      margin-bottom: 1rem;
      border-radius: 8px;
    }

    .info-box strong {
      color: #0d47a1;
    }
  </style>

  <div class="container my-5">
    <div class="card shadow-lg">
      <div class="card-body">
        <!-- Title -->
        <h2 class="card-title">
          <%= guestLecture?.title || "No Title Available" %>
        </h2>

        <!-- Date -->
        <p class="text-muted">
          <strong>Date:</strong>
          <%= guestLecture?.date ? new Date(guestLecture.date).toDateString() : "Not Available" %>
        </p>

        <!-- Conveners -->
        <h5>Conveners:</h5>
        <ul>
          <% if (guestLecture?.conveners?.length > 0) { %>
            <% guestLecture.conveners.forEach(c => { %>
              <li><%= c.name %> (<%= c.designation || "No designation" %>)</li>
            <% }) %>
          <% } else { %>
            <li>No conveners listed</li>
          <% } %>
        </ul>

        <!-- Resource Person -->
        <h5>Resource Person:</h5>
        <% if (guestLecture?.resourcePerson) { %>
          <p><%= guestLecture.resourcePerson.name %> - <%= guestLecture.resourcePerson.role || "Role not available" %></p>
        <% } else { %>
          <p>No resource person info</p>
        <% } %>

        <!-- Registered Participants -->
        <div class="info-box">
          <strong>Registered Participants:</strong>
          <%= guestLecture?.numberOfRegisteredParticipants || 0 %>
        </div>

        <!-- Tracks -->
        <h5>Tracks:</h5>
        <ul>
          <% if (guestLecture?.tracks?.length > 0) { %>
            <% guestLecture.tracks.forEach(track => { %>
              <li><%= track %></li>
            <% }) %>
          <% } else { %>
            <li>No tracks available</li>
          <% } %>
        </ul>

        <!-- Prizes -->
        <h5>Prizes:</h5>
        <ul>
          <li>First Prize: <%= guestLecture?.prizes?.firstPrize || "Not specified" %></li>
          <li>Second Prize: <%= guestLecture?.prizes?.secondPrize || "Not specified" %></li>
          <li>Participation: <%= guestLecture?.prizes?.participation || "Not specified" %></li>
        </ul>

        <!-- Venue -->
        <p class="mt-3"><strong>Venue:</strong> <%= guestLecture?.venue || "Not specified" %></p>

        <!-- Registration -->
        <div class="info-box">
          <strong>Registration:</strong>
          Fee: ₹<%= guestLecture?.registration?.fee ?? "N/A" %> |
          Team Size: <%= guestLecture?.registration?.teamSize ?? "N/A" %>
        </div>

        <!-- Event Summary -->
        <h5>Event Summary:</h5>
        <p><%= guestLecture?.eventSummary || "No summary provided" %></p>

        <!-- Images -->
        <h5>Images:</h5>
        <div class="row">
          <% if (guestLecture?.imageUrl?.length > 0) { %>
            <% guestLecture.imageUrl.forEach(url => { %>
              <div class="col-md-4 mb-3">
                <img src="<%= url %>" class="img-fluid rounded shadow-sm" alt="Event Image">
              </div>
            <% }) %>
          <% } else { %>
            <p>No images available</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <%- include("../partials/footer") %>
</body>

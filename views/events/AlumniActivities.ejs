<body>
  <%- include("../partials/header", { title: "Alumni Activities" }) %>

  <div class="container my-5">
    <h1 class="text-center mb-4">🎓 Alumni Activities</h1>

    <% if (!activities || activities.length === 0) { %>
      <div class="alert alert-warning text-center">
        No Alumni Activities found.
      </div>
    <% } else { %>

      <% activities.forEach(activity => { %>
        <div class="card mb-4 shadow">
          <div class="card-body">

            <!-- ✅ Title -->
            <h2 class="card-title mb-3">
              <%= activity.title || "Untitled Alumni Activity" %>
            </h2>

            <!-- Date & Time -->
            <% if (activity.Date) { %>
              <p><strong>Date:</strong> <%= activity.Date %></p>
            <% } %>

            <% if (activity.Time) { %>
              <p><strong>Time:</strong> <%= activity.Time %></p>
            <% } %>

            <!-- Venue -->
            <% if (activity.Venue) { %>
              <p><strong>Venue:</strong> <%= activity.Venue %></p>
            <% } %>

            <!-- Participants -->
            <% if (activity.Participants) { %>
              <p><strong>Participants:</strong> <%= activity.Participants %></p>
            <% } %>

            <!-- Resource Person -->
            <% if (activity.ResoursePerson) { %>
              <p><strong>Resource Person:</strong> <%= activity.ResoursePerson %></p>
            <% } %>

            <!-- Convener -->
            <% if (activity.convener) { %>
              <p><strong>Convener:</strong> <%= activity.convener %></p>
            <% } %>

            <!-- Summary -->
            <% if (activity.eventsummary) { %>
              <h5>Event Summary</h5>
              <p><%= activity.eventsummary %></p>
            <% } %>

            <!-- Outcome -->
            <% if (activity.eventoutcome) { %>
              <h5>Event Outcome</h5>
              <p><%= activity.eventoutcome %></p>
            <% } %>

            <!-- Images -->
            <% if (activity.images && activity.images.length > 0) { %>
              <h5 class="mt-3">📸 Photos</h5>
              <div class="row">
                <% activity.images.forEach(img => { %>
                  <div class="col-md-4 mb-3">
                    <img src="<%= img %>" class="img-fluid rounded" />
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted">No photos available.</p>
            <% } %>

          </div>
        </div>
      <% }) %>

    <% } %>
  </div>

  <%- include("../partials/footer") %>
</body>

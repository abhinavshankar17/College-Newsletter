<body>
  <%- include("../partials/header", { title: "Alumni Activities" }) %>

  <div class="container my-5">
    <h1 class="text-center mb-4">🎓 Alumni Activities</h1>

    <% if (!activities || activities.length === 0) { %>
      <div class="alert alert-warning text-center">
        No Alumni Activities found.
      </div>
    <% } else { %>

      <% activities.forEach(activity => { %>
        <div class="card mb-4 shadow">
          <div class="card-body">

            <!-- Title -->
            <h2 class="card-title mb-3">
              <%= activity.title || "Untitled Activity" %>
            </h2>

            <!-- Date -->
            <% if (activity.Date) { %>
              <p><strong>Date:</strong> <%= activity.Date %></p>
            <% } %>

            <!-- Time -->
            <% if (activity.Time) { %>
              <p><strong>Time:</strong> <%= activity.Time %></p>
            <% } %>

            <!-- Venue -->
            <% if (activity.Venue) { %>
              <p><strong>Venue:</strong> <%= activity.Venue %></p>
            <% } %>

            <!-- Participants -->
            <% if (activity.Participants) { %>
              <p><strong>Participants:</strong> <%= activity.Participants %></p>
            <% } %>

            <!-- Resource Persons -->
            <% if (activity.ResoursePerson && activity.ResoursePerson.length > 0) { %>
              <h5>Resource Persons</h5>
              <div class="tags-container">
                <% activity.ResoursePerson.forEach(person => { %>
                  <div class="tag"><%= person %></div>
                <% }) %>
              </div>
            <% } %>

            <!-- Conveners -->
            <% if (activity.convener && activity.convener.length > 0) { %>
              <h5>Conveners</h5>
              <div class="tags-container">
                <% activity.convener.forEach(c => { %>
                  <div class="tag"><%= c %></div>
                <% }) %>
              </div>
            <% } %>

            <!-- Event Summary -->
            <% if (activity.eventsummary) { %>
              <h5 class="mt-3">Event Summary</h5>
              <p><%= activity.eventsummary %></p>
            <% } %>

            <!-- Event Outcome -->
            <% if (activity.eventoutcome) { %>
              <h5>Event Outcome</h5>
              <p><%= activity.eventoutcome %></p>
            <% } %>

            <!-- Images -->
            <% if (activity.images && activity.images.length > 0) { %>
              <h5 class="mt-3">📸 Photos</h5>
              <div class="row">
                <% activity.images.forEach(img => { %>
                  <div class="col-md-4 mb-3">
                    <img src="<%= img %>" class="img-fluid rounded" />
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <p class="text-muted">No photos available.</p>
            <% } %>

          </div>
        </div>
      <% }) %>

    <% } %>
  </div>

  <%- include("../partials/footer") %>
</body>

<style>
  .tags-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 15px;
  }

  .tag {
    background: #e8f1fb;
    padding: 8px 14px;
    border-radius: 25px;
    border: 1px solid #cddff7;
    font-size: 0.95rem;
    color: #1b2a49;
    font-weight: 600;
    width: fit-content;
  }

  /* 🔥 Justify all paragraphs */
  .card-body p {
    text-align: justify;
  }
</style>

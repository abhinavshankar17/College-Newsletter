
<body class="bg-light">
      <%- include("../partials/header", { title: "Events Celebrations" }) %>
  <div class="container py-4">
    <h1 class="text-center mb-4">College Celebrations</h1>

    <% if (Events && Events.length > 0) { %>
      <div class="row g-4">
        <% Events.forEach(event => { %>
          <div class="col-md-6">
            <div class="card shadow-sm border-0">
              <div class="card-body">
                <h4 class="card-title text-primary">
                  <%= event.eventTitle || "Untitled Event" %>
                </h4>
                <p class="card-subtitle text-muted mb-2">
                  <strong>Date:</strong> 
                  <%= event.date ? new Date(event.date).toDateString() : "N/A" %>
                </p>
                <p class="mb-1"><strong>Venue:</strong> <%= event.venue || "N/A" %></p>
                <p class="mb-1"><strong>Organizers:</strong> <%= event.organizers || "N/A" %></p>
                <p class="mb-3"><strong>Participants:</strong> <%= event.numberOfParticipants || 0 %></p>

                <% if (event.conveners && event.conveners.length > 0) { %>
                  <h6>Conveners:</h6>
                  <ul class="list-group list-group-flush mb-3">
                    <% event.conveners.forEach(con => { %>
                      <li class="list-group-item">
                        <%= con.name || "Unknown" %> — <%= con.designation || "" %>
                      </li>
                    <% }) %>
                  </ul>
                <% } %>

                <% if (event.coConveners && event.coConveners.length > 0) { %>
                  <h6>Co-Conveners:</h6>
                  <ul class="list-group list-group-flush mb-3">
                    <% event.coConveners.forEach(co => { %>
                      <li class="list-group-item">
                        <%= co.name || "Unknown" %> — <%= co.designation || "" %>
                      </li>
                    <% }) %>
                  </ul>
                <% } %>

                <% if (event.highlights && event.highlights.length > 0) { %>
                  <h6>Highlights:</h6>
                  <ul class="mb-3">
                    <% event.highlights.forEach(hl => { %>
                      <li><%= hl || "" %></li>
                    <% }) %>
                  </ul>
                <% } %>

                <% if (event.eventSummary) { %>
                  <p><strong>Summary:</strong> <%= event.eventSummary %></p>
                <% } %>

                <% if (event.photos && event.photos.length > 0) { %>
                  <div class="mt-3">
                    <h6>Photos:</h6>
                    <div class="d-flex flex-wrap gap-2">
                      <% event.photos.forEach(photo => { %>
                        <img src="<%= photo.url || "/default.jpg" %>" 
                             alt="<%= photo.type || "photo" %>" 
                             class="img-thumbnail" 
                             style="max-width: 150px;">
                      <% }) %>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info text-center">No events found.</div>
    <% } %>
  </div>

<%- include("../partials/footer") %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>


<body class="bg-light">
  <%- include("../partials/header", { title: "Events Celebrations" }) %>

  <div class="container py-5">
    <h1 class="text-center mb-5 fw-bold text-gradient">🎉 College Celebrations 🎉</h1>

    <% if (Events && Events.length > 0) { %>
      <div class="row g-4">
        <% Events.forEach(event => { %>
          <div class="col-12">
            <div class="card shadow-lg border-0 rounded-4 event-card">
              <!-- Card Header -->
              <div class="card-header text-white text-center py-4 rounded-top fw-bold"
                   style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);">
                <h3 class="mb-0"><%= event.eventTitle || "Untitled Event" %></h3>
              </div>

              <!-- Card Body -->
              <div class="card-body p-4">
                <p class="text-muted mb-2">
                  <i class="bi bi-calendar-event"></i>
                  <%= event.date ? new Date(event.date).toDateString() : "N/A" %>
                </p>
                <p class="mb-1"><i class="bi bi-geo-alt-fill text-danger"></i> 
                  <strong>Venue:</strong> <%= event.venue || "N/A" %></p>
                <p class="mb-1"><i class="bi bi-people-fill text-success"></i> 
                  <strong>Organizers:</strong> <%= event.organizers || "N/A" %></p>
                <p class="mb-3">
                  <span class="badge bg-gradient fs-6">
                    👥 <%= event.numberOfParticipants || 0 %> Participants
                  </span>
                </p>

               <!-- Conveners -->
                  <% if (event.conveners && event.conveners.length > 0) { %>
                    <h6 class="section-title">Conveners:</h6>
                    <ul class="list-group list-group-flush small">
                      <% event.conveners.forEach(con => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                          <span><i class="bi bi-person-badge"></i> <%= con.name || "Unknown" %></span>

                          <% if (con.designation === "Principal") { %>
                            <span class="designation-badge designation-principal"><%= con.designation %></span>
                          <% } else if (con.designation === "Head of Department") { %>
                            <span class="designation-badge designation-hod"><%= con.designation %></span>
                          <% } else { %>
                            <span class="designation-badge designation-professor"><%= con.designation %></span>
                          <% } %>
                        </li>
                      <% }) %>
                    </ul>
                  <% } %>

                  <!-- Co-Conveners -->
                  <% if (event.coConveners && event.coConveners.length > 0) { %>
                    <h6 class="section-title">Co-Conveners:</h6>
                    <ul class="list-group list-group-flush small">
                      <% event.coConveners.forEach(co => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                          <span><i class="bi bi-person"></i> <%= co.name || "Unknown" %></span>

                          <% if (co.designation === "Principal") { %>
                            <span class="designation-badge designation-principal"><%= co.designation %></span>
                          <% } else if (co.designation === "Head of Department") { %>
                            <span class="designation-badge designation-hod"><%= co.designation %></span>
                          <% } else { %>
                            <span class="designation-badge designation-professor"><%= co.designation %></span>
                          <% } %>
                        </li>
                      <% }) %>
                    </ul>
                  <% } %>

                <!-- Highlights -->
                <% if (event.highlights && event.highlights.length > 0) { %>
                  <h6 class="section-title">Highlights:</h6>
                  <ul class="mb-3">
                    <% event.highlights.forEach(hl => { %>
                      <li>✨ <%= hl || "" %></li>
                    <% }) %>
                  </ul>
                <% } %>

                <!-- Summary -->
                <% if (event.eventSummary) { %>
                  <p class="mt-3"><strong>Summary:</strong> <%= event.eventSummary %></p>
                <% } %>

                <!-- Images -->
                <% if (event.images && event.images.length > 0) { %>
                  <div class="mt-3">
                    <h6 class="fw-bold text-primary">Event Gallery:</h6>
                    <div class="d-flex flex-wrap gap-3">
                      <% event.images.forEach(image => { %>
                        <img src="<%= image.url || "/default.jpg" %>" 
                             alt="<%= image.type || "image" %>" 
                             class="img-thumbnail event-image" 
                             style="max-width: 180px; border-radius: 12px;">
                      <% }) %>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info text-center shadow-sm p-4 rounded-3">
        🎊 No events found. Be the first to add one!
      </div>
    <% } %>
  </div>

  <%- include("../partials/footer") %>

  <style>
   /* Section Headings (Conveners, Co-Conveners, Highlights, etc.) */
.section-title {
  font-size: 1.15rem;
  font-weight: 600;
  color: #0a1f44; /* Navy Blue */
  margin-top: 1rem;
  margin-bottom: 0.5rem;
  border-left: 4px solid #f1c40f; /* Yellow accent */
  padding-left: 8px;
}

/* Designation Badges */
.designation-badge {
  font-size: 0.8rem;
  font-weight: 600;
  color: #fff;
  background: #0a1f44; /* Navy base */
  padding: 4px 10px;
  border-radius: 6px;
  margin-left: 8px;
  transition: all 0.3s ease;
}

/* Different roles highlighted with yellow */
.designation-principal {
  background: #f1c40f; /* Yellow */
  color: #0a1f44;      /* Navy text for contrast */
}

.designation-hod {
  background: #0a1f44; /* Navy */
  color: #f1c40f;      /* Yellow text */
}

.designation-professor {
  background: #142850; /* Slightly lighter navy */
  color: #f1c40f;      /* Yellow text */
}

/* Hover effect */
.designation-badge:hover {
  transform: scale(1.05);
  opacity: 0.95;
}
.section-title {
  font-size: 1.15rem;
  font-weight: 600;
  color: #0a1f44; /* Navy Blue */
  margin-top: 1rem;
  margin-bottom: 0.5rem;
  border-left: 4px solid #f1c40f; /* Yellow accent */
  padding-left: 8px;
}


  </style>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</body>

<body class="bg-light">
  <%- include("../partials/header", { title: "Events Celebrations" }) %>

  <div class="container py-5">
    <h1 class="text-center mb-5 fw-bold display-5" style="color: #0a1f44;">🎉 College Celebrations 🎉</h1>

    <% if (Events && Events.length > 0) { %>
      <div class="row g-4">
        <% Events.forEach(event => { %>
          <div class="col-12">
            <div class="card shadow-lg border-0 rounded-4 event-card overflow-hidden">

              <!-- Card Header -->
              <div class="card-header text-white text-center py-4 fw-bold event-header">
                <h3 class="mb-0"><%= event.eventTitle || "Untitled Event" %></h3>
              </div>

              <!-- Card Body -->
              <div class="card-body p-4">

                <!-- Number of Participants -->
                <p class="mb-3">
                  <span class="badge participants-badge fs-6">
                     <%= event.numberOfParticipants || 0 %> Participants
                  </span>
                </p>

                <!-- Description -->
                <% if (event.description) { %>
                  <h6 class="section-title">Description:</h6>
                  <p><%= event.description.replace(/\n/g, "<br>") %></p>
                <% } %>

                <!-- Event Summary -->
                <% if (event.eventSummary) { %>
                  <h6 class="section-title">Summary:</h6>
                  <p><%= event.eventSummary.replace(/\n/g, "<br>") %></p>
                <% } %>

                <!-- Images -->
                  <div class="image-grid-container">
  <div class="image-grid">
    <% event.images.forEach(image => { %>
      <img src="<%= image || '/default.jpg' %>" 
           alt="Event Image" 
           class="img-thumbnail event-image">
    <% }) %>
  </div>
</div>
              </div>
            </div>
          </div>  
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info text-center shadow-sm p-4 rounded-3">
        🎊 No events found. Be the first to add one!
      </div>
    <% } %>
  </div>

  <%- include("../partials/footer") %>

  <!-- Custom Styles -->
  <style>
    :root {
      --primary-gradient: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
      --accent-color: #f1c40f;
      --section-title-color: #0a1f44;
      --badge-bg: linear-gradient(45deg, #6a11cb, #2575fc);
    }

    .event-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .event-card:hover {
      transform: scale(1.01);
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
    }

    .event-header {
      background: var(--primary-gradient);
      border-bottom: none;
      border-top-left-radius: 1rem;
      border-top-right-radius: 1rem;
    }

    .participants-badge {
      background: var(--badge-bg);
      color: #fff;
      padding: 0.6rem 1rem;
      border-radius: 20px;
    }

    .section-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--section-title-color);
      margin-top: 1.2rem;
      margin-bottom: 0.5rem;
      border-left: 5px solid var(--accent-color);
      padding-left: 10px;
    }

   .image-grid-container {
  display: flex;
  justify-content: center;
  margin-top: 1rem;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 16px;
  max-width: 1000px; /* Optional: cap the gallery width */
  width: 100%;
  justify-items: center; /* Center images in each grid cell */
}

.event-image {
  width: 100%;
  max-width: 180px;
  height: 160px;
  object-fit: cover;
  border-radius: 12px;
  transition: transform 0.3s ease;
}

.event-image:hover {
  transform: scale(1.05);
}


  </style>

  <!-- Bootstrap JS and Icons -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
</body>

<body class="bg-light">
<%- include("../partials/header", { title: "Events Celebrations" }) %>

<div class="container py-5">
  <h1 class="text-center mb-5 fw-bold text-gradient">🎉 College Celebrations 🎉</h1>

  <% if (Events && Events.length > 0) { %>
    <div class="row g-4">
      <% Events.forEach(event => { %>
        <div class="col-12">
          <div class="card shadow-lg border-0 rounded-4 event-card">

            <!-- Card Header -->
            <div class="card-header text-white text-center py-4 rounded-top fw-bold"
                 style="background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);">
              <h3 class="mb-0"><%= event.eventTitle || "Untitled Event" %></h3>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4">

              <!-- Number of Participants -->
              <p class="mb-3">
                <span class="badge bg-gradient fs-6">
                  👥 <%= event.numberOfParticipants || 0 %> Participants
                </span>
              </p>

              <!-- Description -->
              <% if (event.description) { %>
                <h6 class="section-title">Description:</h6>
                <p><%= event.description.replace(/\n/g, "<br>") %></p>
              <% } %>

              <!-- Event Summary -->
              <% if (event.eventSummary) { %>
                <h6 class="section-title">Summary:</h6>
                <p><%= event.eventSummary.replace(/\n/g, "<br>") %></p>
              <% } %>

              <!-- Images -->
              <% if (event.images && event.images.length > 0) { %>
                <div class="mt-3">
                  <h6 class="fw-bold text-primary">Event Gallery:</h6>
                  <div class="d-flex flex-wrap gap-3">
                    <% event.images.forEach(image => { %>
                      <img src="<%= image || '/default.jpg' %>" 
                           alt="Event Image" 
                           class="img-thumbnail event-image" 
                           style="max-width: 180px; border-radius: 12px;">
                    <% }) %>
                  </div>
                </div>
              <% } %>

            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="alert alert-info text-center shadow-sm p-4 rounded-3">
      🎊 No events found. Be the first to add one!
    </div>
  <% } %>
</div>

<%- include("../partials/footer") %>

<style>
  .section-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #0a1f44; /* Navy Blue */
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    border-left: 4px solid #f1c40f; /* Yellow accent */
    padding-left: 8px;
  }
</style>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">

</body>

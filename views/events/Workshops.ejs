<%- include("../partials/header", { title: "Workshops" }) %>

<div class="container my-5">
  <h1 class="mb-5 text-center fw-bold page-title">Workshops</h1>

  <% if (Object.keys(workshops).length === 0) { %>
    <p class="text-center text-muted">No Workshops available.</p>
  <% } else { %>
    <% Object.keys(workshops).forEach(date => { %>
      <div class="mb-5">
        <h3 class="text-primary mb-4"><%= date %></h3>

        <% workshops[date].forEach(workshop => { %>
          <div class="card shadow-sm mb-4 rounded-3">
            <div class="card-body">
              <h5 class="card-title"><%= workshop.title %></h5>

              <% if (workshop.Convener) { %>
  <p><strong>Convener:</strong></p>
  <% workshop.Convener.split(',').forEach(role => { 
       const r = role.trim();
       if(r){ %>
        <span style="display:block; margin-left:10px;"><%= r %></span>
  <% } }); %>
<% } %>


            <% if(workshop.ResourcePerson){ %>
  <p><strong>Resource Person:</strong></p>
  <% workshop.ResourcePerson.split(',').forEach(person => {
       const p = person.trim();
       if(p){ %>
        <span style="display:block; margin-left:10px;"><%= p %></span>
  <% } }); %>
<% } %>


              <% if(workshop.NumberofRegisteredParticipants){ %>
                <p><strong>Participants:</strong> <%= workshop.NumberofRegisteredParticipants %></p>
              <% } %>

              <% if(workshop.EventSummary){ %>
                <p><strong>Summary:</strong> <%= workshop.EventSummary %></p>
              <% } %>
            </div>

            <!-- Images gallery -->
            <% if(workshop.images && workshop.images.length > 0){ %>
              <div class="card-footer bg-white d-flex flex-wrap gap-2">
                <% workshop.images.forEach(img => { %>
                  <div style="flex:1 1 30%; max-width:30%;">
                    <img src="<%= img %>" class="rounded" style="width:100%; height:150px; object-fit:contain; background:#f0f0f0;" alt="Workshop Image">
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="card-footer bg-white">
                <img src="/images/placeholder.png" class="rounded" style="width:100%; height:150px; object-fit:contain; background:#f0f0f0;" alt="No Image">
              </div>
            <% } %>

          </div>
        <% }) %>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include("../partials/footer") %>

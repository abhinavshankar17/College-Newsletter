<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Workshops</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@500;700&family=Roboto:wght@400;500&display=swap');

    body {
      font-family: 'Roboto', sans-serif;
      color: #333;
      background: #f5f5f5;
    }

    .card {
      border: none;
      border-radius: 15px;
      overflow: hidden;
      background: #fff;
      margin-bottom: 2rem;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    }

    .card-body {
      padding: 2rem;
    }

    .card-title {
      font-family: 'Poppins', sans-serif;
      font-size: 2rem;
      font-weight: 700;
      color: #222;
      border-bottom: 2px solid #eaeaea;
      padding-bottom: 0.5rem;
      margin-bottom: 1.5rem;
    }

    h5 {
      font-family: 'Poppins', sans-serif;
      margin-top: 1.5rem;
      font-weight: 600;
      color: #00695c; /* Teal accent */
      border-left: 4px solid #ccc;
      padding-left: 8px;
    }

    ul {
      padding-left: 1.2rem;
    }

    ul li {
      margin-bottom: 0.4rem;
    }

    .info-box {
      background: #f9f9f9;
      border-left: 4px solid #00695c;
      padding: 0.8rem 1rem;
      margin-bottom: 1rem;
      border-radius: 8px;
    }

    .info-box strong {
      color: #222;
    }

    p, ul {
      margin-bottom: 1rem;
      font-size: 1rem;
    }

    .img-fluid {
      transition: transform 0.3s ease, box-shadow 0.3s ease, border 0.3s ease;
      cursor: pointer;
    }

    .img-fluid:hover {
      transform: scale(1.05);
      border: 2px solid #b71c1c; /* Red only on hover */
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
    }
  </style>
</head>
<body>

  <!-- Header -->
  <%- include("../partials/header", { title: "Workshops" }) %>

  <div class="container my-5">
    <% if (workshops && workshops.length > 0) { %>
      <% workshops.forEach(workshop => { %>
        <div class="card shadow-lg">
          <div class="card-body">
            <!-- Title -->
            <h2 class="card-title"><%= workshop.title %></h2>

            <!-- Dates -->
            <div class="info-box">
              <strong>Date:</strong>
              <% if (workshop.startDate && workshop.endDate) { %>
                <%= new Date(workshop.startDate).toDateString() %> –
                <%= new Date(workshop.endDate).toDateString() %>
              <% } else { %>
                Not Available
              <% } %>
            </div>

            <!-- Conveners -->
            <h5>Conveners:</h5>
            <ul>
              <% if (workshop.conveners?.length > 0) { %>
                <% workshop.conveners.forEach(c => { %>
                  <li><%= c.name %> (<%= c.designation || "No designation" %>)</li>
                <% }) %>
              <% } else { %>
                <li>No conveners listed</li>
              <% } %>
            </ul>

            <!-- Resource Person -->
            <h5>Resource Person:</h5>
            <% if (workshop.resourcePerson) { %>
              <p>
                <%= workshop.resourcePerson.name %>
                - <%= workshop.resourcePerson.role || "Role not available" %>
                <% if (workshop.resourcePerson.organization) { %>
                  , <%= workshop.resourcePerson.organization %>
                <% } %>
              </p>
            <% } else { %>
              <p>No resource person info</p>
            <% } %>

            <!-- Registered Participants -->
            <div class="info-box">
              <strong>Registered Participants:</strong>
              <%= workshop.numberOfRegisteredParticipants || 0 %>
            </div>

            <!-- Venue -->
            <div class="info-box">
              <strong>Venue:</strong> <%= workshop.venue || "Not specified" %>
            </div>

            <!-- Event Summary -->
            <h5>Event Summary:</h5>
            <p><%= workshop.eventSummary || "No summary provided" %></p>

            <!-- Images -->
            <h5>Images:</h5>
            <div class="row">
              <% if (workshop.imageUrl?.length > 0) { %>
                <% workshop.imageUrl.forEach(url => { %>
                  <div class="col-md-4 mb-3">
                    <img src="<%= url %>" class="img-fluid rounded shadow-sm" alt="Workshop Image">
                  </div>
                <% }) %>
              <% } else { %>
                <p>No images available</p>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p>No workshops found.</p>
    <% } %>
  </div>

  <!-- Footer -->
  <%- include("../partials/footer") %>

</body>
</html>

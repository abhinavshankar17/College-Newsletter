<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= workshop?.title || "Workshop Event" %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <!-- Header -->
  <%- include("../partials/header", { title: workshop?.title || "Workshop Event" }) %>

  <div class="container my-5">
    <div class="card shadow-lg">
      <div class="card-body">
        <!-- Title -->
        <h2 class="card-title text-danger mb-3">
          <%= workshop?.title || "No Title Available" %>
        </h2>

        <!-- Dates -->
        <p class="text-muted">
          <strong>Date:</strong>
          <% if (workshop?.startDate && workshop?.endDate) { %>
            <%= new Date(workshop.startDate).toDateString() %> -
            <%= new Date(workshop.endDate).toDateString() %>
          <% } else { %>
            Not Available
          <% } %>
        </p>

        <!-- Conveners -->
        <h5 class="mt-3">Conveners:</h5>
        <ul>
          <% if (workshop?.conveners?.length > 0) { %>
            <% workshop.conveners.forEach(c => { %>
              <li><%= c.name %> (<%= c.designation || "No designation" %>)</li>
            <% }) %>
          <% } else { %>
            <li>No conveners listed</li>
          <% } %>
        </ul>

        <!-- Resource Person -->
        <h5 class="mt-3">Resource Person:</h5>
        <% if (workshop?.resourcePerson) { %>
          <p>
            <%= workshop.resourcePerson.name %>
            - <%= workshop.resourcePerson.role || "Role not available" %>
            <% if (workshop.resourcePerson.organization) { %>
              , <%= workshop.resourcePerson.organization %>
            <% } %>
          </p>
        <% } else { %>
          <p>No resource person info</p>
        <% } %>

        <!-- Registered Participants -->
        <p class="mt-3">
          <strong>Registered Participants:</strong>
          <%= workshop?.numberOfRegisteredParticipants || 0 %>
        </p>

        <!-- Venue -->
        <p><strong>Venue:</strong> <%= workshop?.venue || "Not specified" %></p>

        <!-- Event Summary -->
        <h5 class="mt-3">Event Summary:</h5>
        <p><%= workshop?.eventSummary || "No summary provided" %></p>

        <!-- Images -->
        <h5 class="mt-3">Images:</h5>
        <div class="row">
          <% if (workshop?.imageUrl?.length > 0) { %>
            <% workshop.imageUrl.forEach(url => { %>
              <div class="col-md-4 mb-3">
                <img src="<%= url %>" class="img-fluid rounded shadow-sm" alt="Workshop Image">
              </div>
            <% }) %>
          <% } else { %>
            <p>No images available</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <%- include("../partials/footer") %>
</body>
</html>

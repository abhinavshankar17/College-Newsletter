<%- include("../partials/header", { title: "Cloud Computing Specialization" }) %>

<style>
  body { background-color: #f8f9fa; font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif; }
  h1, h2 { font-weight: 600; color: #2c3e50; }
  .section-title { margin-top: 40px; padding-bottom: 8px; border-bottom: 3px solid #3498db; display: inline-block; }
  .card { border-radius: 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.1); border: none; transition: transform 0.2s; margin-bottom: 20px; padding: 20px; }
  .card:hover { transform: translateY(-4px); }
  .card h4 { color: #2980b9; font-weight: 600; }
  .card p { margin-bottom: 10px; }
  .images-container { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; }
  img.img-thumbnail { border-radius: 8px; max-width: 200px; }
</style>

<div class="container py-4">
  <h1 class="text-center mb-5"><%= data?.title || "Cloud Computing Specialization" %></h1>
  
  <% if (data?.description) { %>
    <p class="lead mb-5 text-center"><%= data.description %></p>
  <% } %>

  <!-- Research Works -->
  <% if (data?.researchWorks) { %>
    <section>
      <h2 class="section-title">Research Works</h2>
      <div class="card">
        <h4><%= data.researchWorks.title %></h4>
        <p><%= data.researchWorks.description %></p>
      </div>
    </section>
  <% } %>

  <!-- Collaborations -->
  <% if (data?.collaborations) { %>
    <section>
      <h2 class="section-title">Industry Collaborations & Training</h2>
      <div class="card">
        <h4><%= data.collaborations.title %></h4>
        <p><%= data.collaborations.description %></p>
        <% if (data.collaborations.images?.length) { %>
          <div class="images-container">
            <% data.collaborations.images.forEach(img => { %>
              <img src="<%= img %>" class="img-thumbnail">
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  <% } %>

  <!-- Workshops -->
  <% if (data?.workshops) { %>
    <section>
      <h2 class="section-title">Workshops</h2>
      <div class="card">
        <h4><%= data.workshops.title %></h4>
        <p><%= data.workshops.description %></p>
        <% if (data.workshops.images?.length) { %>
          <div class="images-container">
            <% data.workshops.images.forEach(img => { %>
              <img src="<%= img %>" class="img-thumbnail">
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  <% } %>

  <!-- Faculty Achievements -->
  <% if (data?.facultyAchievements) { %>
    <section>
      <h2 class="section-title">Faculty Achievements</h2>
      <div class="card">
        <h4><%= data.facultyAchievements.faculty %></h4>
        <p><%= data.facultyAchievements.description %></p>
      </div>
    </section>
  <% } %>

  <!-- Student Achievements -->
  <% if (data?.studentAchievements) { %>
    <section>
      <h2 class="section-title">Student Achievements</h2>
      <div class="card">
        <h4><%= data.studentAchievements.student %></h4>
        <p><%= data.studentAchievements.description %></p>
      </div>
    </section>
  <% } %>

  <!-- Internships -->
  <% if (data?.internships) { %>
    <section>
      <h2 class="section-title">Internships</h2>
      <div class="card">
        <h4><%= data.internships.title %></h4>
        <p><%= data.internships.description %></p>
      </div>
    </section>
  <% } %>

</div>

<%- include("../partials/footer") %>

<%- include("../partials/header", { title: "Information Technology Specialization" }) %>

<style>
  body {
    background-color: #f8f9fa;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  }

  h1, h2 {
    font-weight: 600;
    color: #2c3e50;
  }

  .section-title {
    margin-top: 40px;
    padding-bottom: 8px;
    border-bottom: 3px solid #3498db;
    display: inline-block;
  }

  .card {
    border-radius: 12px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    border: none;
    transition: transform 0.2s;
  }

  .card:hover {
    transform: translateY(-4px);
  }

  .card h4 {
    color: #2980b9;
    font-weight: 600;
  }

  .card p {
    margin-bottom: 6px;
  }

  img.img-thumbnail {
    border-radius: 8px;
  }

  .quote {
    background: #fff9c4;
    padding: 15px;
    margin-top: 30px;
    border-left: 5px solid #facc15;
    font-style: italic;
    text-align: center;
    border-radius: 5px;
  }

  .author {
    display: block;
    font-weight: bold;
    margin-top: 8px;
  }
</style>

<div class="container py-4">
  <h1 class="text-center mb-5">
    <%= data?.title || "Information Technology" %>
  </h1>

  <!-- Doctoral Committees -->
  <section>
    <h2 class="section-title">Doctoral Committee Meetings</h2>
    <% if (data?.doctoralCommittees?.length) { %>
      <% data.doctoralCommittees.forEach(dc => { %>
        <div class="card my-3 p-4">
          <h4><%= dc.memberName %></h4>
          <p><%= dc.details %></p>
          <% if (dc.date) { %><p><strong>Date:</strong> <%= dc.date %></p><% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p>No doctoral committee meetings available.</p>
    <% } %>
  </section>

  <!-- PhD Awardees -->
  <section>
    <h2 class="section-title">PhD Awardees</h2>
    <% if (data?.phdAwardees?.length) { %>
      <% data.phdAwardees.forEach(phd => { %>
        <div class="card my-3 p-4">
          <h4><%= phd.name %></h4>
          <% if (phd.thesisTitle) { %><p><strong>Thesis:</strong> <%= phd.thesisTitle %></p><% } %>
          <% if (phd.supervisor) { %><p><strong>Supervisor:</strong> <%= phd.supervisor %></p><% } %>
          <% if (phd.guidance) { %><p><strong>Guidance:</strong> <%= phd.guidance %></p><% } %>
          <% if (phd.description) { %><p><%= phd.description %></p><% } %>
          <% if (phd.year) { %><p><strong>Year:</strong> <%= phd.year %></p><% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p>No PhD awardees listed.</p>
    <% } %>
  </section>

  <!-- Research Publications -->
  <section>
    <h2 class="section-title">Research Publications</h2>
    <% if (data?.researchPublications?.length) { %>
      <% data.researchPublications.forEach(pub => { %>
        <div class="card my-3 p-4">
          <h4><%= pub.title %></h4>
          <% if (pub.authors?.length) { %>
            <p><strong>Authors:</strong> <%= pub.authors.join(", ") %></p>
          <% } %>
          <% if (pub.venue) { %>
            <p><strong>Venue:</strong> <%= pub.venue %> <%= pub.type ? `(${pub.type})` : "" %></p>
          <% } %>
          <% if (pub.date) { %><p><strong>Date:</strong> <%= pub.date %></p><% } %>
          <% if (pub.issnIsbn) { %><p><strong>ISSN/ISBN:</strong> <%= pub.issnIsbn %></p><% } %>
          <% if (pub.doi) { %><p><strong>DOI:</strong> <%= pub.doi %></p><% } %>
          <% if (pub.link) { %><p><a href="<%= pub.link %>" target="_blank" rel="noopener">View Publication</a></p><% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p>No publications available.</p>
    <% } %>
  </section>

  <!-- Workshops & FDPs -->
  <section>
    <h2 class="section-title">Workshops & FDPs</h2>
    <% if (data?.workshopsAndFDPs?.length) { %>
      <% data.workshopsAndFDPs.forEach(w => { %>
        <div class="card my-3 p-4">
          <h4><%= w.title %></h4>
          <p>
            <% if (w.organizer) { %><strong>Organizer:</strong> <%= w.organizer %><% } %>
            <% if (w.location) { %><% if (w.organizer) { %> | <% } %><strong>Location:</strong> <%= w.location %><% } %>
          </p>
          <% if (w.dates?.length) { %>
            <p><strong>Dates:</strong> <%= w.dates.join(" – ") %></p>
          <% } %>
          <% if (w.participants?.length) { %>
            <p><strong>Participants:</strong> <%= w.participants.join(", ") %></p>
          <% } %>
          <% if (w.description) { %><p><%= w.description %></p><% } %>
          <% if (w.images?.length) { %>
            <div class="images-row mt-2">
              <% w.images.forEach(src => { %>
                <img src="<%= src %>" alt="<%= w.title %>" class="img-thumbnail" width="150" />
              <% }) %>
            </div>
          <% } %>
        </div>
      <% }) %>
    <% } else { %>
      <p>No workshops or FDPs recorded.</p>
    <% } %>
  </section>

  <!-- Gallery -->
  <section>
    <h2 class="section-title">Gallery</h2>
    <% if (data?.images?.length) { %>
      <div class="images-row my-3">
        <% data.images.forEach(src => { %>
          <img src="<%= src %>" alt="IT Image" class="img-thumbnail" width="200" />
        <% }) %>
      </div>
    <% } else { %>
      <p>No images uploaded.</p>
    <% } %>
  </section>

  <!-- Quote -->
  <% if (data?.quote?.text) { %>
    <div class="quote">
      “ <%= data.quote.text %> ”
      <% if (data.quote.author) { %><br><span class="author">– <%= data.quote.author %></span><% } %>
    </div>
  <% } else { %>
    <p class="quote">No inspirational quote yet.</p>
  <% } %>
</div>

<%- include("../partials/footer") %>

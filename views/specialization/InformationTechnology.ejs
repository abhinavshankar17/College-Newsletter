<%- include("../partials/header", { title: "Information Technology Specialization" }) %>

<style>
  body { background-color: #f8f9fa; font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif; }
  h1, h2 { font-weight: 600; color: #2c3e50; }
  .section-title { margin-top: 40px; padding-bottom: 8px; border-bottom: 3px solid #3498db; display: inline-block; }
  .card { border-radius: 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.1); border: none; transition: transform 0.2s; margin-bottom: 15px; padding: 15px; }
  .card:hover { transform: translateY(-4px); }
  .quote { background: #fff9c4; padding: 15px; margin-top: 30px; border-left: 5px solid #facc15; font-style: italic; text-align: center; border-radius: 5px; }
  .images-row img { margin-right: 10px; margin-bottom: 10px; }
</style>

<div class="container py-4">
  <h1 class="text-center mb-5"><%= data?.title || "Information Technology" %></h1>

  <% if (!data) { %>
    <p>No Information Technology data found.</p>
  <% } else { %>

    <!-- Description -->
    <% if (data.description) { %>
      <section>
        <h2 class="section-title">Description</h2>
        <p><%= data.description %></p>
      </section>
    <% } %>

    <!-- Doctoral Committee Meetings -->
    <% if (data.DoctotalCommitteeMeeting) { %>
      <section>
        <h2 class="section-title">Doctoral Committee Meetings</h2>
        <p><%= data.DoctotalCommitteeMeeting %></p>
      </section>
    <% } %>

    <!-- PhD Awardees -->
    <% if (data.phdAwardees) { %>
      <section>
        <h2 class="section-title">PhD Awardees</h2>
        <p><%= data.phdAwardees %></p>
      </section>
    <% } %>

    <!-- Images -->
    <% if (data.images?.length) { %>
      <section>
        <h2 class="section-title">Gallery</h2>
        <div class="images-row">
          <% data.images.forEach(src => { %>
            <img src="<%= src %>" alt="Image" class="img-thumbnail" width="150" />
          <% }) %>
        </div>
      </section>
    <% } %>

    <!-- Research Publications -->
    <% if (data.researchPublications) { %>
      <section>
        <h2 class="section-title">Research Publications</h2>
        <p><%= data.researchPublications %></p>
      </section>
    <% } %>

    <!-- Workshops -->
    <% if (data.Workshops) { %>
      <section>
        <h2 class="section-title">Workshops & FDPs</h2>
        <p><%= data.Workshops %></p>
      </section>
    <% } %>

    <!-- Quote -->
    <% if (data.quote) { %>
      <section>
        <h2 class="section-title">Quote</h2>
        <p class="quote"><%= data.quote %></p>
      </section>
    <% } %>

  <% } %>
</div>

<%- include("../partials/footer") %>

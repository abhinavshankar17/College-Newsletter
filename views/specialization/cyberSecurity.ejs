<%- include("../partials/header", { title: page.title || "Cyber Security" }) %>

<div class="container">
    <h1><%= page.title %></h1>

    <!-- Quote -->
    <% if (page.quote) { %>
        <blockquote><%= page.quote %></blockquote>
    <% } %>

    <!-- Description -->
    <% if (page.description) { %>
        <section>
            <h2>Overview</h2>
            <p><%= page.description %></p>
        </section>
    <% } %>

    <!-- Academic Excellence and Research Output -->
    <% if (page.AcademicExcellenceAndResearchOutput) { %>
        <section>
            <h2>Academic Excellence and Research Output</h2>
            <p><%= page.AcademicExcellenceAndResearchOutput %></p>
        </section>
    <% } %>

    <!-- Internship and Industry Exposure -->
    <% if (page.InternshiptAndIndustryExposure) { %>
        <section>
            <h2>Internship and Industry Exposure</h2>
            <% if (page.InternshiptAndIndustryExposure.description) { %>
                <p><%= page.InternshiptAndIndustryExposure.description %></p>
            <% } %>

            <!-- Handle images -->
            <% if (page.InternshiptAndIndustryExposure.images && page.InternshiptAndIndustryExposure.images.length > 0) { %>
                <div class="images">
                    <% 
                        // If only single image uploaded, wrap in array
                        let internshipImages = Array.isArray(page.InternshiptAndIndustryExposure.images)
                                                ? page.InternshiptAndIndustryExposure.images
                                                : [page.InternshiptAndIndustryExposure.images];
                    %>
                    <% internshipImages.forEach((img) => { %>
                        <img src="<%= img %>" alt="Internship & Industry Exposure" />
                    <% }) %>
                </div>
            <% } %>
        </section>
    <% } %>

    <!-- Faculty Development and Certifications -->
    <% if (page.FacultyDevelopmentAndCertifications) { %>
        <section>
            <h2>Faculty Development and Certifications</h2>
            <p><%= page.FacultyDevelopmentAndCertifications %></p>
        </section>
    <% } %>

    <!-- Outreach, Recognition, and Engagement -->
    <% if (page.OutreachRecognitionAndEngagement) { %>
        <section>
            <h2>Outreach, Recognition, and Engagement</h2>
            <p><%= page.OutreachRecognitionAndEngagement %></p>
        </section>
    <% } %>

    <!-- International Collaboration -->
    <% if (page.InternationalCollaboration) { %>
        <section>
            <h2>International Collaboration</h2>
            <% if (page.InternationalCollaboration.description) { %>
                <p><%= page.InternationalCollaboration.description %></p>
            <% } %>

            <!-- Handle images -->
            <% if (page.InternationalCollaboration.images && page.InternationalCollaboration.images.length > 0) { %>
                <div class="images">
                    <% 
                        // If only single image uploaded, wrap in array
                        let intlImages = Array.isArray(page.InternationalCollaboration.images)
                                                ? page.InternationalCollaboration.images
                                                : [page.InternationalCollaboration.images];
                    %>
                    <% intlImages.forEach((img) => { %>
                        <img src="<%= img %>" alt="International Collaboration" />
                    <% }) %>
                </div>
            <% } %>
        </section>
    <% } %>
</div>

<style>
    .container {
        max-width: 900px;
        margin: auto;
        padding: 20px;
        font-family: Arial, sans-serif;
    }
    h1, h2 {
        color: #0d1b2a;
    }
    blockquote {
        font-style: italic;
        background: #f0f0f0;
        padding: 10px 20px;
        border-left: 5px solid #0d1b2a;
        margin: 20px 0;
    }
    .images img {
        max-width: 100%;
        height: auto;
        margin: 10px 0;
        border-radius: 5px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
</style>

<%- include("../partials/footer") %>

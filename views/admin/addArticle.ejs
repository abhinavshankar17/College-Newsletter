<%- include('../partials/header') %>

<div class="container mt-4">
  <h2>Add Data</h2>

  <form action="/admin/add-article" method="POST" enctype="multipart/form-data">
    <div class="mb-3">
      <label for="pageSelect">Select Page</label>
      <select id="pageSelect" name="page" class="form-select">
        <option value="">-- Select --</option>
        <% Object.keys(pages || {}).forEach(function(page) { %>
          <option value="<%= page %>"><%= page.charAt(0).toUpperCase() + page.slice(1) %></option>
        <% }); %>
      </select>
    </div>

    <div class="mb-3">
      <label for="modelSelect">Select Model</label>
      <select id="modelSelect" name="model" class="form-select">
        <option value="">-- Select --</option>
      </select>
    </div>

    <div id="formFields"></div>

    <button type="submit" class="btn btn-success">Save</button>
  </form>
</div>

<script>
  const pages = JSON.parse('<%- JSON.stringify(pages) %>');
  const schemas = JSON.parse('<%- JSON.stringify(schemas) %>');
  let mouIndex = 1;

  function addMou() {
    const container = document.getElementById("mou-container");
    const newItem = document.createElement("div");
    newItem.classList.add("mou-item", "border", "p-3", "mb-2", "rounded");

    newItem.innerHTML = `
      <label>Company</label>
      <input type="text" name="data[memorandumOfUnderstanding][${mouIndex}][company]" class="form-control mb-2" />
      <label>Details</label>
      <textarea name="data[memorandumOfUnderstanding][${mouIndex}][details]" class="form-control"></textarea>
    `;

    container.appendChild(newItem);
    mouIndex++;
  }

  const pageSelect = document.getElementById("pageSelect");
  const modelSelect = document.getElementById("modelSelect");
  const formFields = document.getElementById("formFields");

  // Format camelCase → nice labels
  function formatLabel(key) {
    return key.replace(/([A-Z])/g, " $1").replace(/^./, str => str.toUpperCase());
  }

  // When page changes → populate models
  pageSelect.addEventListener("change", () => {
    const selectedPage = pageSelect.value;
    modelSelect.innerHTML = "<option value=''>-- Select --</option>";

    if (pages[selectedPage]) {
      pages[selectedPage].models.forEach(m => {
        modelSelect.innerHTML += `<option value="${m}">${formatLabel(m)}</option>`;
      });
    }
    formFields.innerHTML = ""; // Reset form fields
  });

  // When model changes → populate schema fields
  modelSelect.addEventListener("change", async () => {
    const selectedModel = modelSelect.value;
    formFields.innerHTML = "";

    if (selectedModel) {
      try {
        const response = await fetch(`/admin/schema/${selectedModel}`);
        if (!response.ok) throw new Error("Failed to fetch schema fields");
        const fields = await response.json();

        fields.forEach(field => {
  // Never allow _id or __v in dynamic form
  if (field.toLowerCase() === "_id" || field.toLowerCase() === "__v") return;

  // Also block nested _id (like something._id or array._id)
  if (field.endsWith("._id") || field.endsWith("[]._id")) return;


          // Special handling for MoU array
          if (field === "memorandumOfUnderstanding") {
            formFields.innerHTML += `
              <div class="mb-3">
                <label>Memorandum of Understanding</label>
                <div id="mou-container">
                  <div class="mou-item border p-3 mb-2 rounded">
                    <label>Company</label>
                    <input type="text" name="data[memorandumOfUnderstanding][0][company]" class="form-control mb-2" />
                    <label>Details</label>
                    <textarea name="data[memorandumOfUnderstanding][0][details]" class="form-control"></textarea>
                  </div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addMou()">+ Add Another MoU</button>
              </div>
            `;
            return;
          }

          // Default handling
          const isImageField =
            field.toLowerCase().endsWith("imageurl") ||
            field.toLowerCase().endsWith("url") ||
            field.toLowerCase().includes("image") ||
            field.toLowerCase().includes("photo") ||
            field.toLowerCase().includes("gallery");

          formFields.innerHTML += `
            <div class="mb-3">
              <label>${formatLabel(field)}</label>
              ${
                isImageField
                  ? `<input type="file" name="data[${field}][]" class="form-control" multiple />`
                  : `<input type="text" name="data[${field}]" class="form-control" />`
              }
            </div>
          `;
        });
      } catch (error) {
        console.error("Error fetching schema fields:", error);
        alert("Failed to load schema fields. Please try again.");
      }
    }
  });
</script>

<%- include('../partials/footer') %>
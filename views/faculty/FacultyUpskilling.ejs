<%- include("../partials/header", { title: "Faculty Upskilling" }) %>
  <style>
    /* body {
      font-family: Arial, sans-serif;
      background: #f9f9f9;
      margin: 0;
      padding: 20px;
    } */
    /* .container {
      max-width: 900px;
      margin: auto;
    } */
    h1 {
      text-align: center;
      color: #2c3e50;
    }
    .card {
      background: #fff;
      border-radius: 10px;
      padding: 15px;
      margin: 15px 0;
      box-shadow: 0px 2px 6px rgba(0,0,0,0.1);
      display: flex;
      align-items: center;
    }
    .card img {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      margin-right: 20px;
      border: 2px solid #ddd;
    }
    .card .info {
      flex: 1;
    }
    .achievements {
      margin-top: 8px;
      font-size: 14px;
      color: #555;
    }
    .empty-message {
      text-align: center;
      font-style: italic;
      color: #888;
      margin-top: 30px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Faculty Upskilling</h1>

    <% if (faculties && faculties.length > 0) { %>
      <% faculties.forEach(faculty => { %>
        <div class="card">
          <% if (faculty.image) { %>
            <img src="<%= faculty.image %>" alt="<%= faculty.name %>">
          <% } else { %>
            <img src="/images/default-avatar.png" alt="No photo">
          <% } %>

          <div class="info">
            <h2><%= faculty.name %></h2>
            <p><%= faculty.designation %>, <%= faculty.department %></p>

            <div class="achievements">
              <% if (faculty.achievements && faculty.achievements.length > 0) { %>
                <ul>
                  <% faculty.achievements.forEach(ach => { %>
                    <li>
                      <strong><%= ach.title || "Achievement" %></strong> - 
                      <%= ach.description || "" %>
                      <% if (ach.organization) { %> (<%= ach.organization %>) <% } %>
                      <% if (ach.monthYear) { %> - <%= ach.monthYear %> <% } %>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p>No achievements listed.</p>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="empty-message">No faculty upskilling records available yet.</p>
    <% } %>
  </div>

<%- include("../partials/footer") %>
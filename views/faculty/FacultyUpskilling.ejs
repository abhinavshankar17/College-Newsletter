<%- include("../partials/header", { title: "Faculty Upskilling" }) %>
  <style>
 /* Page Background */
body {
  font-family: "Segoe UI", Roboto, Arial, sans-serif;
  background: #f0f2f5; /* light gray */
  margin: 0;
  padding: 0;
  color: #2c3e50;
}

/* Container */
.container {
  max-width: 950px;
  margin: 0 auto;
  padding: 20px;
}

/* Page Heading */
h1 {
  text-align: center;
  font-size: 2.2rem;
  font-weight: 700;
  color: #1f2933; /* dark gray */
  margin-bottom: 30px;
  line-height: 1.4;
}
h1::after {
  content: "";
  display: block;
  width: 80px;
  height: 4px;
  background: #6b7280; /* medium gray accent */
  margin: 12px auto 0;
  border-radius: 2px;
}

/* Faculty Card */
.card {
  background: #ffffff; /* keep cards white for contrast */
  border-radius: 14px;
  padding: 20px;
  margin: 20px 0;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
}

/* Faculty Image */
.card img {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  object-fit: cover;
  margin-right: 20px;
  border: 2px solid #d1d5db; /* light gray border */
  transition: transform 0.3s ease;
}
.card img:hover {
  transform: scale(1.05);
}

/* Info Section */
.card .info {
  flex: 1;
}
.card .info h2 {
  margin: 0 0 8px;
  font-size: 1.4rem;
  color: #111827;
  font-weight: 600;
}
.card .info p {
  margin: 4px 0;
  font-size: 1rem;
  color: #4b5563; /* gray text */
}
.card .info p strong {
  color: #374151; /* darker gray accent */
  font-weight: 600;
}

/* Achievements List */
.achievements {
  margin-top: 10px;
  font-size: 0.95rem;
  color: #4b5563;
}
.achievements ul {
  padding-left: 20px;
  margin: 0;
}
.achievements li {
  margin-bottom: 6px;
}
.achievements li strong {
  color: #6b7280; /* medium gray accent */
}

/* Empty Message */
.empty-message {
  text-align: center;
  font-style: italic;
  color: #6b7280;
  margin-top: 50px;
  font-size: 1.1rem;
}

  </style>
</head>
<body>
  <div class="container">
    <h1>Faculty Upskilling</h1>

    <% if (faculties && faculties.length > 0) { %>
      <% faculties.forEach(faculty => { %>
        <div class="card">
          <% if (faculty.image) { %>
            <img src="<%= faculty.image %>" alt="<%= faculty.name %>">
          <% } else { %>
            <img src="/images/default-avatar.png" alt="No photo">
          <% } %>

          <div class="info">
            <h2><%= faculty.name %></h2>
            <p><%= faculty.designation %>, <%= faculty.department %></p>

            <div class="achievements">
              <% if (faculty.achievements && faculty.achievements.length > 0) { %>
                <ul>
                  <% faculty.achievements.forEach(ach => { %>
                    <li>
                      <strong><%= ach.title || "Achievement" %></strong> - 
                      <%= ach.description || "" %>
                      <% if (ach.organization) { %> (<%= ach.organization %>) <% } %>
                      <% if (ach.monthYear) { %> - <%= ach.monthYear %> <% } %>
                    </li>
                  <% }) %>
                </ul>
              <% } else { %>
                <p>No achievements listed.</p>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="empty-message">No faculty upskilling records available yet.</p>
    <% } %>
  </div>

<%- include("../partials/footer") %>
<%- include("../partials/header", { title: "Faculty Upskilling" }) %>

<style>

/* =========================
   Base Styles
========================= */
body {
  font-family: "Segoe UI", Roboto, Arial, sans-serif;
  background: #f0f2f5;
  margin: 0;
  padding: 0;
  color: #1f2937;
  line-height: 1.6;
  scroll-behavior: smooth;
}

/* =========================
   Container
========================= */
.container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 20px;
}

/* =========================
   Page Heading
========================= */
h1 {
  text-align: center;
  font-size: clamp(1.8rem, 4vw, 2.4rem);
  font-weight: 700;
  color: #111827;
  margin-bottom: 40px;
  line-height: 1.3;
  position: relative;
}

h1::after {
  content: "";
  display: block;
  width: 120px;
  height: 4px;
  background: linear-gradient(90deg, #4f46e5, #6366f1);
  margin: 14px auto 0;
  border-radius: 2px;
}

/* =========================
   Cards Grid
========================= */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  margin-top: 20px;
}

/* =========================
   Card Styles
========================= */
.card {
  background: #ffffff;
  border-radius: 18px;
  padding: 20px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  transition: transform 0.35s ease, box-shadow 0.35s ease, background 0.35s ease;
  text-align: justify;
}

.card:hover {
  transform: translateY(-6px) scale(1.02);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
  background: #f9fafb;
}

/* =========================
   Card Image
========================= */
.card img {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  object-fit: cover;
  margin-right: 20px;
  border: 3px solid #d1d5db;
  transition: transform 0.3s ease, border-color 0.3s ease;
}

.card img:hover {
  transform: scale(1.08);
  border-color: #4f46e5;
}

/* =========================
   Card Info Section
========================= */
.card .info {
  flex: 1;
}

.card .info h2 {
  margin: 0 0 6px;
  font-size: 1.4rem;
  color: #1f2937;
  font-weight: 700;
}

.card .info p {
  margin: 4px 0;
  font-size: 0.95rem;
  color: #4b5563;
}

.card .info p strong {
  color: #4f46e5;
  font-weight: 600;
}

/* =========================
   Description — Soft Justification
========================= */
.card .description {
  margin-top: 6px;
  font-size: 0.9rem;
  color: #6b7280;
  font-style: italic;
  line-height: 1.5;

  /* Soft justification */
  text-align: justify;
  text-justify: inter-word;

  /* Prevent wide spacing */
  max-width: 95%;
  margin-right: auto;

  /* Handle long words */
  hyphens: auto;
  overflow-wrap: break-word;
}

/* Do NOT justify very short descriptions (looks bad) */
.card .description.short {
  text-align: left;
}

/* =========================
   Empty Message
========================= */
.empty-message {
  text-align: center;
  font-style: italic;
  color: #6b7280;
  margin-top: 60px;
  font-size: 1.15rem;
  background: #f3f4f6;
  display: inline-block;
  padding: 16px 24px;
  border-radius: 12px;
  box-shadow: inset 0 2px 6px rgba(0,0,0,0.05);
}

/* =========================
   Responsive
========================= */
@media (max-width: 768px) {
  h1 { font-size: 2rem; }
  .card {
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 18px 16px;
  }
  .card img { margin: 0 0 12px 0; }
  .card .info h2 { font-size: 1.3rem; }
}

@media (max-width: 480px) {
  h1 { font-size: 1.8rem; }
  .cards-grid { gap: 16px; }
  .card { padding: 16px; }
  .card .info h2 { font-size: 1.2rem; }
}

</style>


<div class="container">
  <h1>Faculty Upskilling</h1>

  <% if (faculties && faculties.length > 0) { %>
    <div class="cards-grid">
      <% faculties.forEach(member => { 
           const imgSrc = (member.images && member.images.length > 0)
                          ? member.images[0]
                          : '/images/default-avatar.png';
           const isShort = member.description && member.description.length < 140;
      %>
        <div class="card">
          <img src="<%= imgSrc %>" alt="<%= member.name || 'No photo' %>">
          <div class="info">
            <% if (member.name) { %>
              <h2><%= member.name %></h2>
            <% } %>
            <p><%= member.designation %>, <%= member.department %></p>

            <% if (member.description) { %>
              <div class="description <%= isShort ? 'short' : '' %>">
                <%= member.description %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty-message">No faculty upskilling records available yet.</p>
  <% } %>
</div>

<%- include("../partials/footer") %>

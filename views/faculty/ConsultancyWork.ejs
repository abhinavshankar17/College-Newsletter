<%- include("../partials/header", { title: "Consultancies" }) %>

<div class="container my-5">
  <h1 class="mb-5 text-center fw-bold page-title">Consultancies</h1>

  <% if (!consultancies || consultancies.length === 0) { %>
    <p class="text-center text-muted">No Consultancy data available.</p>
  <% } else { %>
    <% consultancies.forEach(cons => { %>
      <div class="card shadow-sm mb-4 rounded-3">
        <div class="card-body">
          <% if(cons.title){ %>
            <h5 class="card-title"><%= cons.title %></h5>
          <% } %>

          <% if(cons.description1){ %>
            <p><strong>Description:</strong> <%= cons.description1 %></p>
          <% } %>

          <% if(cons.consultancyCompany){ %>
            <p><strong>Company:</strong> <%= cons.consultancyCompany %></p>
          <% } %>

          <% if(cons.consultancyAmount){ %>
            <p><strong>Amount:</strong> ₹<%= cons.consultancyAmount %></p>
          <% } %>

          <% if(cons.Member){ %>
            <div>
              <p><strong>Member Details:</strong></p>
              <% if(cons.Member.name){ %>
                <span style="display:block; margin-left:10px;"><strong>Name:</strong> <%= cons.Member.name %></span>
              <% } %>
              <% if(cons.Member.designation){ %>
                <span style="display:block; margin-left:10px;"><strong>Designation:</strong> <%= cons.Member.designation %></span>
              <% } %>
              <% if(cons.Member.department){ %>
                <span style="display:block; margin-left:10px;"><strong>Department:</strong> <%= cons.Member.department %></span>
              <% } %>
            </div>
          <% } %>
        </div>

        <!-- Member images gallery -->
        <% if(cons.Member && cons.Member.images && cons.Member.images.length > 0){ %>
          <div class="card-footer bg-white d-flex flex-wrap gap-2">
            <% cons.Member.images.forEach(img => { %>
              <div style="flex:1 1 30%; max-width:30%;">
                <img src="<%= img %>" class="rounded" style="width:100%; height:150px; object-fit:contain; background:#f0f0f0;" alt="Member Image">
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="card-footer bg-white">
            <img src="/images/placeholder.png" class="rounded" style="width:100%; height:150px; object-fit:contain; background:#f0f0f0;" alt="No Image">
          </div>
        <% } %>

      </div>
    <% }) %>
  <% } %>
</div>

<%- include("../partials/footer") %>

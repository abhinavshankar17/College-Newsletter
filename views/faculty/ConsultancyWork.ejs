<%- include("../partials/header", { title: "Consultancies" }) %>

<style>
  .consultancy-card {
    border-radius: 14px;
    padding: 24px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.12);
    margin-bottom: 38px;
    background: #fff;
    transition: 0.25s ease;
  }

  .consultancy-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.18);
  }

  .consultancy-title {
    color: #b71c1c;
    text-align: center;
    font-weight: 700;
    font-size: 1.7rem;
    margin-bottom: 6px;
  }

  .consultancy-company {
    color: #c62828;
    text-align: center;
    font-weight: 600;
    font-size: 1.15rem;
    margin-bottom: 10px;
  }

  .consultancy-amount {
    color: #1b5e20;
    text-align: center;
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 18px;
  }

  .member-row {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    justify-content: flex-start;
    margin-bottom: 18px;
  }

  .member-card {
    flex: 1 1 48%;
    
    border-radius: 12px;
    border: 1px solid #e0e0e0;
    padding: 14px;
    display: flex;
    align-items: flex-start;
    gap: 18px;
    background: #fafafa;
    transition: 0.3s ease;
  }

  .member-card:hover {
    background: #f4f4f4;
  }

.member-card img {
  width: 100px;          /* slightly bigger */
  height: auto;          /* allow height to scale */
  max-height: 120px;     /* optional max height */
  object-fit: contain;   /* ensures full image is visible */
  border-radius: 8px;
  background: #f0f0f0;
}

  .member-info {
    flex: 1;
    min-width: 0;
  }

  /* Label-value flex layout without fixed width */
  .member-info span {
    display: flex;
    gap: 6px; /* space between label and value */
    font-size: 1rem;
    color: #333;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }

  .member-info span strong {
    font-weight: 600;
    color: #1a202c;
  }

  .description-only {
    padding: 16px;
    background: #e3f2fd;
    border-left: 5px solid #1565c0;
    border-radius: 8px;
    margin-top: 14px;
  }

  .description-only p {
    margin: 0;
    font-size: 1rem;
    color: #37474f;
    text-align: justify;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .member-card {
      flex: 1 1 100%;
      max-width: 100%;
    }
    .member-card img {
      width: 90px;
      height: 90px;
    }
  }
</style>

<div class="container my-5">
  <h1 class="mb-5 text-center fw-bold page-title">Consultancies</h1>

  <% if (!consultancies || consultancies.length === 0) { %>
    <p class="text-center text-muted">No Consultancy data available.</p>
  <% } else { %>

    <!-- Descriptions without image -->
    <% consultancies
      .filter(c => !c.Member || !c.Member.images || c.Member.images.length === 0)
      .forEach(cons => { %>

      <% if (cons.description && cons.description.trim() !== "") { %>
        <div class="consultancy-card">
          <% if (cons.title) { %>
            <div class="consultancy-title"><%= cons.title %></div>
          <% } %>
          <% if (cons.consultancyCompany) { %>
            <div class="consultancy-company"><%= cons.consultancyCompany %></div>
          <% } %>
          <% if (cons.consultancyAmount) { %>
            <div class="consultancy-amount">₹<%= cons.consultancyAmount %></div>
          <% } %>
          <div class="description-only">
            <p><%= cons.description %></p>
          </div>
        </div>
      <% } %>
    <% }) %>

    <!-- With images (2 per row) -->
    <div class="row">
      <% consultancies
        .filter(c => c.Member && c.Member.images && c.Member.images.length > 0)
        .forEach(cons => { %>

        <div class="col-md-6 mb-4">
          <div class="consultancy-card">
            <% if (cons.title) { %>
              <div class="consultancy-title"><%= cons.title %></div>
            <% } %>
            <% if (cons.consultancyCompany) { %>
              <div class="consultancy-company"><%= cons.consultancyCompany %></div>
            <% } %>
            <% if (cons.consultancyAmount) { %>
              <div class="consultancy-amount">₹<%= cons.consultancyAmount %></div>
            <% } %>

            <div class="member-row">
              <div class="member-card">
                <img src="<%= cons.Member.images[0] %>" alt="Member Image">

                <div class="member-info">
                  <% if (cons.Member.name) { %>
                    <span><strong>Name:</strong> <%= cons.Member.name %></span>
                  <% } %>
                  <% if (cons.Member.designation) { %>
                    <span><strong>Designation:</strong> <%= cons.Member.designation %></span>
                  <% } %>
                  <% if (cons.Member.department) { %>
                    <span><strong>Department:</strong> <%= cons.Member.department %></span>
                  <% } %>
                </div>
              </div>
            </div>

            <% if (cons.description) { %>
              <div class="description-only">
                <p><%= cons.description %></p>
              </div>
            <% } %>
          </div>
        </div>

      <% }) %>
    </div>

  <% } %>
</div>

<%- include("../partials/footer") %>

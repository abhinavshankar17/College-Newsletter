<%- include("../partials/header", { title: "Ph.D. Scholars" }) %>

<style>
/* Base Styles */
body {
  font-family: "Segoe UI", Roboto, Arial, sans-serif;
  background: linear-gradient(135deg, #f0f4f8, #ffffff);
  margin: 0;
  color: #1f2937;
}

/* Header */
h1 {
  text-align: center;
  font-size: 2.6rem;
  font-weight: 700;
  color: #1e293b;
  margin: 60px 20px 40px;
  line-height: 1.2;
  position: relative;
}

h1::after {
  content: "";
  display: block;
  width: 140px;
  height: 4px;
  background: linear-gradient(to right, #4f46e5, #6366f1);
  margin: 16px auto 0;
  border-radius: 2px;
}

/* Scholar Container */
.scholar-container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 28px;
  padding: 0 20px 60px;
  max-width: 1200px;
  margin: 0 auto;
}

/* Scholar Card */
.scholar-card {
  background: #ffffff;
  border-radius: 18px;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  padding: 26px 22px;
  transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
  display: flex;
  flex-direction: column;
}

.scholar-card:hover {
  transform: translateY(-6px) scale(1.02);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
  background: #f9fafb;
}

/* Scholar Text */
.scholar-card p {
  margin: 6px 0;
  font-size: 1rem;
  color: #4b5563;
  line-height: 1.5;
}

.scholar-card p strong {
  background: linear-gradient(90deg, #4f46e5, #6366f1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 700;
  font-size: 1.1rem;
  display: inline-block;
}

/* No Data */
.no-data {
  text-align: center;
  font-size: 1.3rem;
  color: #6b7280;
  margin-top: 80px;
  padding: 40px 20px;
}

.no-data p {
  background: #f3f4f6;
  display: inline-block;
  padding: 18px 26px;
  border-radius: 14px;
  font-style: italic;
  box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.05);
}

/* Responsive */
@media (max-width: 768px) {
  h1 { font-size: 2.3rem; }
  .scholar-card { padding: 22px 18px; }
}

@media (max-width: 480px) {
  h1 { font-size: 2rem; }
  .scholar-card { padding: 18px 14px; }
}
</style>

<body>
  <h1>Ph.D. Powerhouse!<br>Driving Scholarly Achievement</h1>

  <% if (!scholars || !scholars.length) { %>
    <div class="no-data">
      <p>No Ph.D. scholar data available at the moment.</p>
    </div>
  <% } else { %>
    <div class="scholar-container">
      <% scholars.forEach(function(scholar) { %>
        <div class="scholar-card">
          <p>
            <strong><%= scholar.name %></strong>
          </p>
          <% if (scholar.regNo) { %>
            <p>Reg. No: <%= scholar.regNo %></p>
          <% } %>
          <% if (scholar.description) { %>
            <p><%= scholar.description %></p>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>
   <div class="text-center">
    <h2 class="fw-bold congrats">🎉 Congratulations 🎉</h2>
  </div>
</body>

<%- include("../partials/footer") %>

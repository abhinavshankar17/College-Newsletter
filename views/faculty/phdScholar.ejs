<%- include("../partials/header", { title: "Ph.D. Scholars" }) %>

<style>
/* Base Styles */
/* =========================
   Base Styles
========================= */
body {
  font-family: "Segoe UI", Roboto, Arial, sans-serif;
  background: linear-gradient(135deg, #f0f4f8, #ffffff);
  margin: 0;
  color: #1f2937;
  line-height: 1.6;
  scroll-behavior: smooth;
}

h1 {
  text-align: center;
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 800;
  color: #1e293b;
  margin: 60px 20px 40px;
  position: relative;
  text-shadow: 0 0 12px rgba(251, 191, 36, 0.25);
}

h1::after {
  content: "";
  display: block;
  width: 140px;
  height: 4px;
  background: linear-gradient(to right, #fbbf24, #facc15);
  margin: 16px auto 0;
  border-radius: 4px;
}

/* =========================
   Scholar Container
========================= */
.scholar-container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 28px;
  padding: 0 20px 60px;
  max-width: 1200px;
  margin: 0 auto;
}

/* =========================
   Scholar Card
========================= */
.scholar-card {
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
  padding: 26px 22px;
  transition: all 0.35s ease;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  text-align: justify;
}

.scholar-card:hover {
  transform: translateY(-6px) scale(1.03);
  box-shadow: 0 20px 45px rgba(251, 191, 36, 0.25);
  background: #fef9f1;
}

/* Scholar Text */
.scholar-card p {
  margin: 6px 0;
  font-size: 1rem;
  color: #4b5563;
  line-height: 1.7;
}

.scholar-card p strong {
  font-size: 1.1rem;
  font-weight: 700;
  background: linear-gradient(90deg, #facc15, #fbbf24);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  display: inline-block;
}

/* =========================
   No Data
========================= */
.no-data {
  text-align: center;
  font-size: 1.3rem;
  color: #6b7280;
  margin-top: 80px;
  padding: 40px 20px;
}

.no-data p {
  background: #f3f4f6;
  display: inline-block;
  padding: 18px 26px;
  border-radius: 14px;
  font-style: italic;
  box-shadow: inset 0 2px 6px rgba(0, 0, 0, 0.05);
}

/* =========================
   Congratulations Section
========================= */
.congrats {
  margin: 40px 0 80px;
  font-size: 2rem;
  color: #1e3a8a;
  text-align: center;
  text-shadow: 0 3px 8px rgba(0, 0, 0, 0.15);
}

/* =========================
   Yellow Accent Enhancements
========================= */
.yellow-accent {
  background: linear-gradient(90deg, #fbbf24, #facc15);
  height: 6px;
  width: clamp(120px, 30vw, 220px);
  margin: 18px auto;
  border-radius: 4px;
}

/* =========================
   Responsive
========================= */
@media (max-width: 768px) {
  h1 { font-size: 2.3rem; }
  .scholar-card { padding: 22px 18px; }
}

@media (max-width: 480px) {
  h1 { font-size: 2rem; }
  .scholar-card { padding: 18px 14px; }
}

</style>

<body>
  <h1>Ph.D. Powerhouse!<br>Driving Scholarly Achievement</h1>

  <% if (!scholars || !scholars.length) { %>
    <div class="no-data">
      <p>No Ph.D. scholar data available at the moment.</p>
    </div>
  <% } else { %>
    <div class="scholar-container">
      <% scholars.forEach(function(scholar) { %>
        <div class="scholar-card">
          <p>
            <strong><%= scholar.name %></strong>
          </p>
          <% if (scholar.regNo) { %>
            <p>Reg. No: <%= scholar.regNo %></p>
          <% } %>
          <% if (scholar.description) { %>
            <p><%= scholar.description %></p>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="text-center">
    <h2 class="fw-bold congrats">🎉 Congratulations 🎉</h2>
  </div>
</body>

<%- include("../partials/footer") %>

<%- include("../partials/header", { title: "Ph.D. Scholars" }) %>

<style>

/* =========================
   PAGE BACKGROUND
========================= */

body{
font-family:"Inter","Segoe UI",sans-serif;
background:linear-gradient(135deg,#e3f2fd,#fffde7);
margin:0;
color:#1e293b;
}

/* =========================
   PAGE TITLE
========================= */

h1{
text-align:center;
font-size:2.8rem;
margin:70px 0 50px;
font-weight:800;
color:#0d47a1;
letter-spacing:.5px;
}

/* =========================
   CONTAINER
========================= */

.scholar-container{

max-width:1300px;
margin:auto;
padding:0 40px;

display:flex;
flex-direction:column;
gap:30px;

}

/* =========================
   GLASS CARD
========================= */

.scholar-card{

display:flex;
align-items:center;
gap:35px;

padding:28px;

border-radius:18px;

background:rgba(255,255,255,0.45);

backdrop-filter:blur(14px);

-webkit-backdrop-filter:blur(14px);

border:1px solid rgba(255,255,255,0.4);

box-shadow:0 12px 35px rgba(0,0,0,0.08);

transition:all .35s ease;

position:relative;

overflow:hidden;

}

/* animated yellow glow */

.scholar-card::before{

content:"";

position:absolute;

inset:0;

background:linear-gradient(120deg,transparent,rgba(255,213,79,.4),transparent);

opacity:0;

transition:opacity .4s;

}

.scholar-card:hover::before{

opacity:1;

}

/* hover animation */

.scholar-card:hover{

transform:translateY(-6px) scale(1.01);

box-shadow:0 18px 45px rgba(0,0,0,0.16);

}

/* =========================
   IMAGE
========================= */

.scholar-img{

flex-shrink:0;

display:flex;
justify-content:center;
align-items:center;

background:#f8fafc;

padding:10px;

border-radius:14px;

}

.scholar-img img{

width:260px;
height:260px;

object-fit:cover;

border-radius:14px;

border:4px solid #ffd54f;

transition:transform .5s ease;

}

.scholar-card:hover .scholar-img img{

transform:scale(1.08);

}

/* =========================
   INFO
========================= */

.scholar-info{

flex:1;

}

.scholar-name{

font-size:1.6rem;
font-weight:800;
margin-bottom:12px;
color:#0d47a1;

}

.scholar-info p{

font-size:.98rem;
color:#374151;
margin:7px 0;

}

.scholar-info strong{

color:#111827;

}

/* Description */

.scholar-desc{

margin-top:14px;
line-height:1.7;
color:#4b5563;

}

/* =========================
   MOBILE
========================= */

@media(max-width:900px){

.scholar-card{

flex-direction:column;
text-align:center;

}

.scholar-img img{

width:220px;
height:220px;

}

}

</style>


<h1>Ph.D. Scholars</h1>


<div class="scholar-container">

<% scholars.forEach(function(scholar) { %>

<div class="scholar-card">

<% if (scholar.images && scholar.images.length > 0) { %>

<div class="scholar-img">
<img src="<%= scholar.images[0] %>" alt="<%= scholar.name %>">
</div>

<% } %>


<div class="scholar-info">

<p class="scholar-name">
<%= scholar.name %>
</p>


<% if (scholar.regNo) { %>
<p><strong>Reg. No:</strong> <%= scholar.regNo %></p>
<% } %>


<% if (scholar.mode) { %>
<p><strong>Mode:</strong> <%= scholar.mode %></p>
<% } %>


<% if (scholar.supervisor) { %>
<p><strong>Research Supervisor:</strong> <%= scholar.supervisor %></p>
<% } %>


<% if (scholar.completionDate) { %>
<p>
<strong>Date of Completion:</strong>
<%= new Date(scholar.completionDate).toLocaleDateString("en-GB", {
day: "2-digit",
month: "long",
year: "numeric"
}) %>
</p>
<% } %>


<% if (scholar.description) { %>
<p class="scholar-desc">
<%= scholar.description %>
</p>
<% } %>

</div>

</div>

<% }) %>

</div>

<%- include("../partials/footer") %>
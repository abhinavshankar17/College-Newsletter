<%- include("../partials/header", { title: "Ph.D. Scholars" }) %>

<style>
body {
  font-family: "Segoe UI", Roboto, Arial, sans-serif;
  background: linear-gradient(135deg, #f0f4f8, #ffffff);
  margin: 0;
  color: #2c3e50;
}

h1 {
  text-align: center;
  font-size: 2.4rem;
  font-weight: 700;
  color: #1e293b;
  margin: 40px 20px 40px;
  line-height: 1.3;
  position: relative;
}

h1::after {
  content: "";
  display: block;
  width: 100px;
  height: 4px;
  background: linear-gradient(to right, #4f46e5, #6366f1);
  margin: 16px auto 0;
  border-radius: 2px;
}

.scholar-container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 24px;
  padding: 0 20px 60px;
  max-width: 1200px;
  margin: 0 auto;
}

.scholar-card {
  background: #ffffff;
  border-radius: 20px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
  padding: 28px 24px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.scholar-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 28px rgba(0, 0, 0, 0.15);
}

.scholar-card h2 {
  margin: 0 0 14px;
  font-size: 1.5rem;
  color: #111827;
  font-weight: 600;
}

.scholar-card p {
  margin: 8px 0;
  font-size: 1rem;
  color: #4b5563;
  line-height: 1.5;
}

.scholar-card p strong {
  color: #4f46e5;
  font-weight: 600;
}

.no-data {
  text-align: center;
  font-size: 1.3rem;
  color: #6b7280;
  margin-top: 80px;
  padding: 40px 20px;
}

.no-data p {
  background: #f3f4f6;
  display: inline-block;
  padding: 16px 24px;
  border-radius: 14px;
  font-style: italic;
  box-shadow: inset 0 2px 6px rgba(0,0,0,0.05);
}

@media (max-width: 480px) {
  h1 {
    font-size: 2rem;
  }
  .scholar-card {
    padding: 20px 16px;
  }
}
</style>


<body>
  <h1>Ph.D. Powerhouse!<br>Driving Scholarly Achievement</h1>

 <div class="scholar-container">
  <% scholars.forEach(function(scholar) { %>
    <div class="scholar-card">
      <% for (let i = 1; i <= 6; i++) { %>
        <% const nameKey = `name${i}`; %>
        <% const descKey = `description${i}`; %>
        <% if (scholar[nameKey] || scholar[descKey]) { %>
          <p>
            <% if (scholar[nameKey]) { %>
              <strong> <%= scholar[nameKey] %><br></strong>
            <% } %>
            <% if (scholar[descKey]) { %>
             <%= scholar[descKey] %>
            <% } %>
          </p>
        <% } %>
      <% } %>
    </div>
  <% }) %>
</div>

</body>

<%- include("../partials/footer") %>

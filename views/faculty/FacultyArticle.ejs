<%- include('../partials/header', { title: "Faculty Articles" }) %>

<div class="container my-5">
  <h1 class="mb-4 fw-bold">📚 Faculty Articles</h1>

  <% if (articles && articles.length > 0) { %>
    <div class="row">
      <% articles.forEach(article => { %>
        <div class="col-md-6 mb-4">
          <div class="card shadow-sm h-100">
            <% if (article.images && article.images.length > 0) { %>
              <div class="d-flex flex-wrap p-2">
                <% article.images.forEach(img => { %>
                  <img src="<%= img %>" alt="Article Image" class="img-fluid rounded mb-2 me-2" style="max-width: 150px;">
                <% }) %>
              </div>
            <% } %>

            <div class="card-body">
              <h2 class="card-title h5 mb-2"><%= article.title || "Untitled Article" %></h2>
              <% if (article.name) { %>
                <p class="text-muted mb-2">
                  <strong><%= article.name %></strong>
                  <% if (article.designation) { %> – <%= article.designation %> <% } %>
                </p>
              <% } %>

              <% if (article.description) { %>
                <p class="mb-2"><%= article.description %></p>
              <% } %>

              <% if (article.quote) { %>
                <blockquote class="blockquote border-start border-3 ps-3 mt-2">
                  <p class="mb-0">"<%= article.quote %>"</p>
                </blockquote>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-muted fst-italic">No faculty articles found.</p>
  <% } %>
</div>

<%- include('../partials/footer') %>

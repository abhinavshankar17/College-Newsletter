<body class="bg-light">
  <%- include("../partials/header", { title: "Faculty Articles" }) %>

  <div class="container my-5">
    <h1 class="mb-4 fw-bold">📚 Faculty Articles</h1>

    <% if (articles && articles.length > 0) { %>
      <% articles.forEach(article => { %>
        <div class="card shadow-sm mb-4">
          <div class="card-body">

            <!-- Title -->
            <h2 class="card-title h4 mb-2"><%= article.title || "Untitled Article" %></h2>

            <!-- Author -->
            <% if (article.author && article.author.name) { %>
              <p class="text-muted mb-3">
                <strong><%= article.author.name %></strong>
                <% if (article.author.designation) { %> – <%= article.author.designation %> <% } %>
              </p>
            <% } %>

            <!-- Images -->
            <% if (article.images && article.images.length > 0) { %>
              <div class="mb-3">
                <% article.images.forEach(img => { %>
                  <img src="<%= img %>" alt="Article Image" class="img-fluid rounded mb-2 me-2" style="max-width: 200px;">
                <% }) %>
              </div>
            <% } %>

            <!-- Content -->
            <% if (article.content) { %>
              <p class="mb-3"><%= article.content %></p>
            <% } %>

            <!-- Quote -->
            <% if (article.quotes && article.quotes.text) { %>
              <blockquote class="blockquote border-start border-3 ps-3 mt-3">
                <p class="mb-0">"<%= article.quotes.text %>"</p>
              </blockquote>
            <% } %>

          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-muted fst-italic">No faculty articles found.</p>
    <% } %>
  </div>

  <%- include("../partials/footer") %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

<style>
body.bg-light {
  font-family: "Segoe UI", Roboto, Arial, sans-serif;
  color: #2c3e50;
  background: #f9fafb;
}

h1 {
  font-size: 2.2rem;
  color: #1e293b;
  border-bottom: 3px solid #4f46e5;
  display: inline-block;
  padding-bottom: 0.3rem;
  margin-bottom: 2rem;
}

.card {
  border: none;
  border-radius: 1rem;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card:hover {
  transform: translateY(-5px);
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
}

.card-body {
  padding: 1.8rem;
}

.card-title {
  color: #111827;
  font-weight: 600;
  transition: color 0.2s;
}

.card-title:hover {
  color: #4f46e5;
}

.text-muted { font-size: 0.95rem; }

.blockquote {
  font-style: italic;
  background: #f1f5f9;
  border-radius: 0.5rem;
  padding: 1rem 1.2rem;
}
</style>

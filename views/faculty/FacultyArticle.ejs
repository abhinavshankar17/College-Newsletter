<body class="bg-light">
  <%- include("../partials/header", { title: "Faculty Articles" }) %>

  <div class="container my-5">
    <h1 class="mb-4 fw-bold">📚 Faculty Articles</h1>

    <% if (articles && articles.length > 0) { %>
      <% articles.forEach(article => { %>
        <div class="card shadow-sm mb-4">
          <div class="card-body">
            <!-- Title -->
            <h2 class="card-title h4 mb-2"><%= article.title || "Untitled Article" %></h2>

            <!-- Author -->
            <p class="text-muted mb-3">
              <%= article.author?.name || "Unknown Author" %>
              <% if (article.author?.designation) { %>
                – <%= article.author.designation %>
              <% } %>
            </p>

            <!-- Cover Image -->
            <% if (article.coverImage) { %>
              <img src="<%= article.coverImage %>" alt="Cover" class="img-fluid rounded mb-3">
            <% } %>

            <!-- Sections -->
            <% if (article.sections && article.sections.length > 0) { %>
              <% article.sections.forEach(section => { %>
                <div class="mb-3">
                  <% if (section.heading) { %>
                    <h3 class="h5 fw-semibold"><%= section.heading %></h3>
                  <% } %>
                  <% if (section.content) { %>
                    <p><%= section.content %></p>
                  <% } %>
                  <% if (section.images && section.images.length > 0) { %>
                    <div class="mb-3">
                      <% section.images.forEach(image => { %>
                        <img src="<%= image %>" alt="Section Image" class="img-fluid rounded mb-2">
                      <% }) %>
                    </div>
                  <% } %>
                  <% if (section.listItems && section.listItems.length > 0) { %>
                    <ul class="list-group list-group-flush">
                      <% section.listItems.forEach(item => { %>
                        <li class="list-group-item"><%= item %></li>
                      <% }) %>
                    </ul>
                  <% } %>
                </div>
              <% }) %>
            <% } else { %>
              <p class="text-muted fst-italic">No sections available.</p>
            <% } %>

            <!-- Quotes -->
            <% if (article.quotes && article.quotes.length > 0) { %>
              <blockquote class="blockquote border-start border-3 ps-3 mt-3">
                <% article.quotes.forEach(quote => { %>
                  <p class="mb-1">"<%= quote.text %>"</p>
                  <br>
                  <% if (quote.author) { %>
                    <footer class="blockquote-footer"><%= quote.author %></footer>
                  <% } %>
                <% }) %>
              </blockquote>
            <% } %>

            <!-- Tags -->
            <% if (article.tags && article.tags.length > 0) { %>
              <div class="mt-3">
                <% article.tags.forEach(tag => { %>
                  <span class="badge bg-secondary me-1"><%= tag %></span>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-muted fst-italic">No faculty articles found.</p>
    <% } %>
  </div>

<%- include("../partials/footer") %>
  <!-- Bootstrap JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
<style>
  /* General Body Styling */
body.bg-light {
  font-family: "Segoe UI", Roboto, Arial, sans-serif;
  color: #2c3e50;
  background: #f9fafb;
}

/* Page Heading */
h1 {
  font-size: 2.2rem;
  color: #1e293b;
  border-bottom: 3px solid #4f46e5;
  display: inline-block;
  padding-bottom: 0.3rem;
  margin-bottom: 2rem;
}

/* Article Card */
.card {
  border: none;
  border-radius: 1rem;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.card:hover {
  transform: translateY(-5px);
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
}
.card-body {
  padding: 1.8rem;
}

/* Article Title */
.card-title {
  color: #111827;
  font-weight: 600;
  transition: color 0.2s;
}
.card-title:hover {
  color: #4f46e5;
}

/* Author Text */
.text-muted {
  font-size: 0.95rem;
}

/* Section Headings */
h3.h5 {
  color: #2563eb;
  margin-bottom: 0.6rem;
}

/* Lists inside Sections */
.list-group-item {
  border: none;
  padding-left: 0;
  padding-right: 0;
  background: transparent;
}
.list-group-item::before {
  content: "• ";
  color: #4f46e5;
  font-weight: bold;
  margin-right: 6px;
}

/* Quotes */
.blockquote {
  font-style: italic;
  background: #f1f5f9;
  border-radius: 0.5rem;
  padding: 1rem 1.2rem;
}
.blockquote-footer {
  font-size: 0.85rem;
  color: #475569;
}

/* Tags */
.badge {
  background: #4f46e5 !important;
  font-size: 0.85rem;
  padding: 0.5em 0.75em;
  border-radius: 999px;
  transition: background 0.2s;
}
.badge:hover {
  background: #1e3a8a !important;
}

</style>


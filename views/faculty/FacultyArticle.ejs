
<body class="bg-light">
  <%- include("../partials/header", { title: "Faculty Articles" }) %>

  <div class="container my-5">
    <h1 class="mb-4 fw-bold">📚 Faculty Articles</h1>

    <% if (articles && articles.length > 0) { %>
      <% articles.forEach(article => { %>
        <div class="card shadow-sm mb-4">
          <div class="card-body">
            <!-- Title -->
            <h2 class="card-title h4 mb-2"><%= article.title || "Untitled Article" %></h2>

            <!-- Author -->
            <p class="text-muted mb-3">
              <%= article.author?.name || "Unknown Author" %>
              <% if (article.author?.designation) { %>
                – <%= article.author.designation %>
              <% } %>
            </p>

            <!-- Cover Image -->
            <% if (article.coverImage) { %>
              <img src="<%= article.coverImage %>" alt="Cover" class="img-fluid rounded mb-3">
            <% } %>

            <!-- Sections -->
            <% if (article.sections && article.sections.length > 0) { %>
              <% article.sections.forEach(section => { %>
                <div class="mb-3">
                  <% if (section.heading) { %>
                    <h3 class="h5 fw-semibold"><%= section.heading %></h3>
                  <% } %>
                  <% if (section.content) { %>
                    <p><%= section.content %></p>
                  <% } %>
                  <% if (section.listItems && section.listItems.length > 0) { %>
                    <ul class="list-group list-group-flush">
                      <% section.listItems.forEach(item => { %>
                        <li class="list-group-item"><%= item %></li>
                      <% }) %>
                    </ul>
                  <% } %>
                </div>
              <% }) %>
            <% } else { %>
              <p class="text-muted fst-italic">No sections available.</p>
            <% } %>

            <!-- Quotes -->
            <% if (article.quotes && article.quotes.length > 0) { %>
              <blockquote class="blockquote border-start border-3 ps-3 mt-3">
                <% article.quotes.forEach(quote => { %>
                  <p class="mb-1">"<%= quote.text %>"</p>
                  <% if (quote.author) { %>
                    <footer class="blockquote-footer"><%= quote.author %></footer>
                  <% } %>
                <% }) %>
              </blockquote>
            <% } %>

            <!-- Tags -->
            <% if (article.tags && article.tags.length > 0) { %>
              <div class="mt-3">
                <% article.tags.forEach(tag => { %>
                  <span class="badge bg-secondary me-1"><%= tag %></span>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-muted fst-italic">No faculty articles found.</p>
    <% } %>
  </div>

<%- include("../partials/footer") %>
  <!-- Bootstrap JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>


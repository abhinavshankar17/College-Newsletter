<%- include("../partials/header", { title: "Faculty Achievement" }) %>

<style>
  body {
    background-color: #f8f9fa;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  }

  h1 {
    text-align: center;
    color: #2c3e50;
    margin-bottom: 30px;
  }

  .card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    padding: 20px;
    margin-bottom: 25px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }

  .card h3 {
    color: #2980b9;
    margin-top: 0;
    font-weight: 600;
  }

  .card p {
    margin: 5px 0;
    color: #34495e;
  }

  .card .faculty-img {
    float: right;
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 8px;
    border: 2px solid #ddd;
    margin-left: 20px;
  }

  .card ul {
    margin: 5px 0 0 20px;
    padding: 0;
  }

  .card ul li {
    margin-bottom: 4px;
  }

  .card .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #1f2937;
    margin-top: 15px;
    margin-bottom: 8px;
    border-bottom: 2px solid #3498db;
    display: inline-block;
    padding-bottom: 3px;
  }
</style>

<div class="container py-4">
  <h1>Faculty Achievements</h1>

  <% if (achievements && achievements.length > 0) { %>
    <% achievements.forEach(achievement => { %>
      <div class="card">
        <!-- Faculty Info -->
        <% if (achievement.imageUrl && achievement.imageUrl.length > 0) { %>
          <img src="<%= achievement.imageUrl[0] %>" alt="Faculty Photo" class="faculty-img">
        <% } %>
        <h3><%= achievement.facultyName || "N/A" %></h3>
        <p><strong>Designation:</strong> <%= achievement.designation || "N/A" %></p>
        <p><strong>Department:</strong> <%= achievement.department || "N/A" %></p>
        <p><strong>Institution:</strong> <%= achievement.institution || "N/A" %></p>

        <!-- Achievement Info -->
        <p class="section-title">Achievement Details</p>
        <p><strong>Title:</strong> <%= achievement.title || "Untitled Achievement" %></p>
        <p><strong>Type:</strong> <%= achievement.achievementType || "N/A" %></p>
        <p><strong>Description:</strong> <%= achievement.description || "No description provided." %></p>
        <p><strong>Organization:</strong> <%= achievement.organization || "N/A" %></p>
        <p><strong>Event:</strong> <%= achievement.event || "N/A" %></p>
        <p><strong>Role:</strong> <%= achievement.role || "N/A" %></p>
        <p><strong>Recognition:</strong> <%= achievement.recognition || "N/A" %></p>
        <p><strong>Dates:</strong> 
          <% if (achievement.startDate) { %>
            <%= new Date(achievement.startDate).toLocaleDateString() %>
          <% } else { %>
            N/A
          <% } %> -
          <% if (achievement.endDate) { %>
            <%= new Date(achievement.endDate).toLocaleDateString() %>
          <% } else { %>
            Present
          <% } %>
        </p>

        <!-- Collaborators -->
        <% if (achievement.collaborators?.length > 0) { %>
          <p class="section-title">Collaborators</p>
          <ul>
            <% achievement.collaborators.forEach(col => { %>
              <li><strong><%= col.name || "N/A" %></strong> - <%= col.role || "N/A" %> 
              <% if (col.regNo) { %> (Reg No: <%= col.regNo %>) <% } %></li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    <% }) %>
  <% } else { %>
    <p class="text-center mt-5">No achievements have been added yet.</p>
  <% } %>
</div>

<%- include("../partials/footer") %>

<%- include('../partials/header', { title: "Faculty Achievements" }) %>

<style>

/* =========================
   Base
========================= */

body{
font-family:"Inter","Segoe UI",sans-serif;
background:linear-gradient(135deg,#e3f2fd,#fffde7);
min-height:100vh;
color:#1e293b;
}

/* =========================
   Page Title
========================= */

.achievements-title{
font-weight:800;
letter-spacing:.5px;
color:#0d47a1;
text-align:center;
margin-bottom:50px;
}

/* =========================
   Group Header
========================= */

.group-header{
background:linear-gradient(135deg,#1565c0,#0d47a1);
color:white;
padding:16px 25px;
border-radius:14px 14px 0 0;
font-weight:600;
}

.group-header h3{
margin:0;
}

/* =========================
   Glass Card
========================= */

.achievement-card{

display:flex;
align-items:center;
gap:30px;

padding:25px;

margin-bottom:25px;

border-radius:16px;

background:rgba(255,255,255,0.45);

backdrop-filter:blur(14px);

-webkit-backdrop-filter:blur(14px);

border:1px solid rgba(255,255,255,0.4);

box-shadow:0 10px 35px rgba(0,0,0,0.08);

transition:all .35s ease;

position:relative;

overflow:hidden;

}

/* hover glow */

.achievement-card::before{

content:"";

position:absolute;

inset:0;

background:linear-gradient(120deg,transparent,rgba(255,213,79,.4),transparent);

opacity:0;

transition:opacity .4s;

}

.achievement-card:hover::before{

opacity:1;

}

/* hover animation */

.achievement-card:hover{

transform:translateY(-6px) scale(1.01);

box-shadow:0 18px 45px rgba(0,0,0,0.15);

}

/* =========================
   Image
========================= */

.image-wrapper{

flex-shrink:0;

overflow:hidden;

border-radius:12px;

}

.achievement-img{
 height:100px;
object-fit:cover;

border-radius:12px;

border:4px solid #ffd54f;

transition:transform .5s ease;

}

.achievement-card:hover .achievement-img{

transform:scale(1.08);

}

/* =========================
   Text Content
========================= */

.achievement-content{

flex:1;

}

.card-title{

font-size:1.25rem;

font-weight:700;

color:#0d47a1;

margin-bottom:6px;

}

.card-text{

font-size:.96rem;

color:#475569;

line-height:1.7;

}

/* =========================
   Text Only Block
========================= */

.no-image-text-block{

padding:20px;

border-left:6px solid #ffd54f;

background:rgba(255,255,255,.65);

backdrop-filter:blur(10px);

border-radius:10px;

margin-bottom:20px;

}

.text-only-title{

font-weight:700;

color:#0d47a1;

margin-bottom:4px;

}

.text-only-description{

color:#475569;

}

/* =========================
   Empty Message
========================= */

.alert-info{

background:#e3f2fd;

border:none;

color:#0d47a1;

padding:18px;

border-radius:10px;

text-align:center;

}

/* =========================
   Responsive
========================= */

@media(max-width:900px){

.achievement-card{

flex-direction:column;

text-align:center;

}

.achievement-img{

width:100%;

height:220px;

}

}

</style>

<div class="container my-5">

<h1 class="achievements-title">Faculty Achievements</h1>

<% if (!groupedAchievements || Object.keys(groupedAchievements).length === 0) { %>

<div class="alert alert-info">
No faculty achievements available.
</div>

<% } else { %>

<% for (let title in groupedAchievements) { %>

<div class="mb-5">

<div class="group-header">
<h3><%= title %></h3>
</div>

<div class="mt-4">

<% groupedAchievements[title].forEach((item)=>{ %>

<% if(item.images && item.images.length>0){ %>

<!-- Image Card -->

<div class="achievement-card">

<div class="image-wrapper">
<img src="<%= item.images[0] %>" class="achievement-img" alt="Faculty Achievement">
</div>

<div class="achievement-content">

<h5 class="card-title">
<%= item.designation || "" %>
</h5>

<p class="card-text">
<%= item.description || "" %>
</p>

</div>

</div>

<% } else { %>

<!-- Text Only -->

<div class="no-image-text-block">

<div class="text-only-title">
<%= item.designation || "" %>
</div>

<div class="text-only-description">
<%= item.description || "" %>
</div>

</div>

<% } %>

<% }) %>

</div>

</div>

<% } %>

<% } %>

</div>

<%- include('../partials/footer') %>
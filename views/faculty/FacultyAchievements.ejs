<%- include('../partials/header', { title: "Faculty Achievements" }) %>

<div class="container my-5">
  <h1 class="text-center fw-bold mb-5">Faculty Achievements</h1>

  <% if (!groupedAchievements || Object.keys(groupedAchievements).length === 0) { %>
    <div class="alert alert-info text-center">
      No faculty achievements available.
    </div>
  <% } else { %>
    <% for (let title in groupedAchievements) { %>
      <div class="card mb-5 shadow-sm">
        <div class="card-header bg-primary text-white">
          <h3 class="mb-0"><%= title %></h3>
        </div>

        <div class="card-body">
          <div class="row">
            <% groupedAchievements[title].forEach((item) => { %>
              <div class="col-md-4 mb-4 d-flex">
                <div class="card flex-fill h-100 border-0 shadow-sm">
                  <% if (item.images && item.images.length > 0) { %>
                    <img src="<%= item.images[0] %>" class="card-img-top img-fluid rounded-top" alt="Faculty Achievement Image">
                  <% } else { %>
                    <div class="bg-light text-center p-4 text-muted">No Image</div>
                  <% } %>
                  
                  <div class="card-body">
                    <h5 class="card-title"><%= item.designation || "No Designation" %></h5>
                    <p class="card-text"><%= item.description || "No description provided." %></p>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    <% } %>
  <% } %>
</div>

<%- include('../partials/footer') %>

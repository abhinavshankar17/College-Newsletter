<%- include("../partials/header", { title: "Faculty Achievement" }) %>

<style>
  body {
    background-color: #f8f9fa;
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
  }

  h1 {
    text-align: center;
    color: #2c3e50;
    margin-bottom: 30px;
  }

  .card {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    padding: 20px;
    margin-bottom: 25px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }

  .card h3 {
    color: #2980b9;
    margin-top: 0;
    font-weight: 600;
  }

  .card p {
    margin: 5px 0;
    color: #34495e;
  }

  .card .faculty-img {
    float: right;
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 8px;
    border: 2px solid #ddd;
    margin-left: 20px;
  }

  .card ul {
    margin: 5px 0 0 20px;
    padding: 0;
  }

  .card ul li {
    margin-bottom: 4px;
  }

  .card .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #1f2937;
    margin-top: 15px;
    margin-bottom: 8px;
    border-bottom: 2px solid #3498db;
    display: inline-block;
    padding-bottom: 3px;
  }
</style>


<div class="container my-5">
  <h2 class="text-center fw-bold mb-4">Faculty Achievements</h2>

  <% if (achievements && achievements.length > 0) { %>
    <% achievements.forEach(achievement => { %>
      <div class="card shadow-lg p-4 rounded-3 mb-5">
        <hr class="my-4 border border-2 border-dashed">

        <!-- Faculty Members -->
        <div class="mb-5">
          <h4 class="text-center fw-semibold mb-3">Faculty Members</h4>
          <div class="row justify-content-center g-4">
            <% const members = [achievement.faculty1, achievement.faculty2, achievement.faculty3, achievement.faculty4, achievement.faculty5, achievement.faculty6]; %>
            <% members.forEach(member => { %>
              <% if (member && (member.name || member.designamtion || member.description)) { %>
                <div class="col-md-3 col-sm-6 text-center team-member">
                  <% 
                    // Handle single image safely
                    const imgSrc = member.images 
                                   ? (Array.isArray(member.images) ? member.images[0] : member.images) 
                                   : null;
                  %>
                  <% if (imgSrc) { %>
                    <img src="<%= imgSrc %>" 
                         alt="<%= member.name || 'Faculty' %>" 
                         class="rounded-circle shadow mb-2" 
                         style="width: 100px; height: 100px; object-fit: cover;">
                  <% } else { %>
                    <div class="rounded-circle placeholder mb-2" 
                         style="width: 100px; height: 100px; display:flex; align-items:center; justify-content:center; background:#9ca3af; color:#fff;">
                      No Photo
                    </div>
                  <% } %>
                  <p class="fw-bold mb-0"><%= member.name || "Unknown" %></p>
                  <p class="text-muted small mb-0"><%= member.designamtion || "N/A" %></p>
                  <p class="text-muted small"><%= member.description || "" %></p>
                </div>
              <% } %>
            <% }) %>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p class="text-center fst-italic text-muted">No faculty achievements available yet.</p>
  <% } %>
</div>



<%- include("../partials/footer") %>

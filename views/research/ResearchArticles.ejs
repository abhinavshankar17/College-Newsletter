<%- include("../partials/header", { title: "Research Articles" }) %>

<div class="container py-4 rp-container">
  <h1 class="mb-4 text-center">Research Articles</h1>

<div style="max-width: 800px; margin: 40px auto; text-align: center; font-family: 'Poppins', sans-serif;">

  <p style="font-weight: 600; line-height: 1.8; margin-bottom: 20px;">
    • <b>Journal Publications</b>: Over <b>30 papers</b> published in reputed SCI/Scopus indexed international journals <br>
    • <b>Conference Publications</b>: More than <b>40 papers</b> presented in leading IEEE and Springer international conferences
  </p>

  <p style="line-height: 1.9; font-size: 15px; margin: 0;">
    The Department of Networking and Communications proudly presents the research contributions 
    of its faculty members and scholars published in reputed international journals and conferences 
    during October to December 2025. The publications span multiple domains including 
    <b>Artificial Intelligence</b>, <b>Cybersecurity</b>, <b>Internet of Things (IoT)</b>, 
    <b>Healthcare Technologies</b>, <b>Smart Systems</b>, and <b>Sustainable Computing</b>, 
    reflecting the department’s multidisciplinary research excellence.
  </p>

</div>
  <% Object.keys(groupedArticles || {}).forEach(function(headline) { %>
    <h2 class="rp-section-title"><%= headline %></h2>
    <div class="row g-3 mb-4">
      <% (groupedArticles[headline] || []).forEach(function(p) { %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0 p-3">
            <h5 class="card-title rp-card-title mb-2"><%= p.headline %></h5>

            <% if (p.authors && p.authors.length) { %>
              <p class="mb-1"><strong>Authors:</strong> <%= p.authors.join(", ") %></p>
            <% } %>

            <% if (p.journal) { %>
              <p class="mb-1"><strong>Journal:</strong> <%= p.journal %></p>
            <% } %>

            <% if (p.issn) { %>
              <p class="mb-1"><strong>ISSN:</strong> <%= p.issn %></p>
            <% } %>

            <% if(p.year) { %>
              <p class="mb-0"><strong>Year:</strong> <%= new Date(p.year).getFullYear() %></p>
            <% } %>

            <% if (p.description) { %>
              <p class="text-muted"><%= p.description %></p>
            <% } %>
          </div>
        </div>
      <% }); %>
    </div>
    <hr class="my-4">
  <% }); %>
</div>

<%- include("../partials/footer") %>

<style>
  /* ===== Container Styling ===== */
  .rp-container {
    background: #ffffff;
    border-radius: 12px;
    padding: 2rem;
  }

  h1 {
    text-align: center;
    font-weight: 700;
    color: #0d1b2a;
    margin-bottom: 2rem;
  }

  .rp-section-title {
    font-weight: 600;
    color: #0d1b2a;
    position: relative;
    display: inline-block;
    padding-bottom: 6px;
    margin-bottom: 1.5rem;
  }

  .rp-section-title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    height: 3px;
    width: 50%;
    background: #ffcc00;
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  .rp-section-title:hover::after {
    width: 100%;
  }

  .card {
    border: none;
    border-radius: 12px;
    background: #f9fafc;
    transition: all 0.3s ease, transform 0.25s cubic-bezier(.4,2,.6,1), box-shadow 0.25s;
    box-shadow: 0 2px 8px rgba(33, 150, 243, 0.07);
  }

  .card:hover {
    transform: translateY(-8px) scale(1.03);
    box-shadow: 0 12px 32px rgba(255, 204, 0, 0.18); /* Yellow glow */
    border: 1px solid #ffeb99; /* Soft yellow border */
    background: #fff9e6; /* Light yellow background */
  }

  .card-title.rp-card-title {
    position: relative;
    z-index: 1;
  }

  .card-title.rp-card-title::after {
    content: "";
    display: block;
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 3px;
    background: #ffcc00; /* Yellow underline */
    border-radius: 2px;
    transition: width 0.3s;
    z-index: -1;
  }

  .card:hover .card-title.rp-card-title::after {
    width: 60%;
  }

  .card p {
    margin-bottom: 0.5rem;
    color: #333;
  }

  .card strong {
    color: #0d1b2a;
  }

  hr.my-4 {
    border-top: 2px dashed #e3e3e3;
    opacity: 0.7;
    margin-top: 2.5rem;
    margin-bottom: 2.5rem;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .rp-container {
      padding: 1rem;
    }
    .card {
      margin-bottom: 1rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const cards = document.querySelectorAll('.card');
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = 1;
          entry.target.style.transform += ' scale(1.02)';
        }
      });
    }, { threshold: 0.15 });

    cards.forEach(card => {
      card.style.opacity = 0;
      observer.observe(card);
    });
  });
</script>
